# Polarion Configuration
POLARION_URL=https://polarion.engineering.redhat.com
POLARION_PROJECT=OSE

# Polarion REST API Authentication (required)
# Generate token at: https://polarion.engineering.redhat.com/polarion/#/user/me
POLARION_TOKEN=your_personal_access_token_here

# Polarion SOAP API Authentication (optional - only for updating test steps on existing TCs)
# Required if you need to update test steps on existing test cases
# New test cases can add steps during creation without these
POLARION_USERNAME=your_username
POLARION_PASSWORD=your_password

# GitHub Configuration (optional)
GITHUB_TOKEN=your_github_token_here
GITHUB_ORG=openshift
GITHUB_REPO=machine-config-operator

# Jira Configuration (for fetch_jira.py)
JIRA_URL=https://redhat.atlassian.net
JIRA_EMAIL=you@redhat.com
JIRA_TOKEN=your_jira_api_token_here
# Generate token at: https://id.atlassian.com/manage-profile/security/api-tokens
# For Basic Auth: base64(email:token) - script handles this automatically
# For Bearer: just use token - script tries Bearer first, falls back to Basic

# MCO Test Defaults
MCO_COMPONENT=Machine Config Operator
MCO_SUB_TEAM=MCO
MCO_TEST_TYPE=Functional
MCO_PRODUCTS=OCP
MCO_DEFAULT_VERSION=4.22

# SSL Verification (for development/testing)
VERIFY_SSL=true
