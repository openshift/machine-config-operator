{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01U98nWAvrkAT5iUqqBDuDy4","type":"tool_result","content":"1\tpackage helpers\n2\t\n3\timport (\n4\t\tmcfgv1 \"github.com/openshift/api/machineconfiguration/v1\"\n5\t\t\"github.com/openshift/machine-config-operator/pkg/apihelpers\"\n6\t\tcorev1 \"k8s.io/api/core/v1\"\n7\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n8\t\t\"k8s.io/apimachinery/pkg/util/intstr\"\n9\t)\n10\t\n11\t// MachineConfigPoolBuilder provides a more fluent API for creating\n12\t// MachineConfigPool objects for tests. Instead of creating multiple specific\n13\t// functions for each particular node configuration, this allows one to create\n14\t// nodes thusly:\n15\t//\n16\t// NewMachineConfigPoolBuilder(\"worker\").WithMachineConfig(currentConfig).MachineConfigPool()\n17\t//\n18\t// It is aware of the rules around creating layering-enabled\n19\t// MachineConfigPools. For example, if one sets an image with the WithImage()\n20\t// method, it will automatically set the layering annotation.\n21\ttype MachineConfigPoolBuilder struct {\n22\t\tname           string\n23\t\tcurrentConfig  string\n24\t\tannos          map[string]string\n25\t\tlabels         map[string]string\n26\t\tmcSelector     *metav1.LabelSelector\n27\t\tnodeSelector   *metav1.LabelSelector\n28\t\tconditions     []*mcfgv1.MachineConfigPoolCondition\n29\t\tmaxUnavailable *intstr.IntOrString\n30\t\tpaused         bool\n31\t\tchildConfigs   []corev1.ObjectReference\n32\t}\n33\t\n34\tfunc NewMachineConfigPoolBuilder(name string) *MachineConfigPoolBuilder {\n35\t\treturn &MachineConfigPoolBuilder{name: name}\n36\t}\n37\t\n38\tfunc (m *MachineConfigPoolBuilder) WithName(name string) *MachineConfigPoolBuilder {\n39\t\tm.name = name\n40\t\treturn m\n41\t}\n42\t\n43\tfunc (m *MachineConfigPoolBuilder) WithPaused() *MachineConfigPoolBuilder {\n44\t\tm.paused = true\n45\t\treturn m\n46\t}\n47\t\n48\tfunc (m *MachineConfigPoolBuilder) WithMaxUnavailable(n int) *MachineConfigPoolBuilder {\n49\t\t// TODO: Update k8s.io/apimachinery since this now uses an int32 instead of an int.\n50\t\ttmp := intstr.FromInt(n)\n51\t\tm.maxUnavailable = &tmp\n52\t\treturn m\n53\t}\n54\t\n55\tfunc (m *MachineConfigPoolBuilder) WithMachineConfig(mc string) *MachineConfigPoolBuilder {\n56\t\tm.currentConfig = mc\n57\t\treturn m\n58\t}\n59\t\n60\tfunc (m *MachineConfigPoolBuilder) WithAnnotations(annos map[string]string) *MachineConfigPoolBuilder {\n61\t\tif m.annos == nil {\n62\t\t\tm.annos = map[string]string{}\n63\t\t}\n64\t\n65\t\tfor k, v := range annos {\n66\t\t\tm.annos[k] = v\n67\t\t}\n68\t\n69\t\treturn m\n70\t}\n71\t\n72\tfunc (m *MachineConfigPoolBuilder) WithLabels(labels map[string]string) *MachineConfigPoolBuilder {\n73\t\tif m.labels == nil {\n74\t\t\tm.labels = map[string]string{}\n75\t\t}\n76\t\n77\t\tfor k, v := range labels {\n78\t\t\tm.labels[k] = v\n79\t\t}\n80\t\n81\t\treturn m\n82\t}\n83\t\n84\tfunc (m *MachineConfigPoolBuilder) WithChildConfigs(names []string) *MachineConfigPoolBuilder {\n85\t\tif m.childConfigs == nil {\n86\t\t\tm.childConfigs = []corev1.ObjectReference{}\n87\t\t}\n88\t\n89\t\tfor _, name := range names {\n90\t\t\tm.childConfigs = append(m.childConfigs, corev1.ObjectReference{\n91\t\t\t\tName: name,\n92\t\t\t\tKind: \"MachineConfig\",\n93\t\t\t})\n94\t\t}\n95\t\n96\t\treturn m\n97\t}\n98\t\n99\tfunc (m *MachineConfigPoolBuilder) WithNodeSelector(ns *metav1.LabelSelector) *MachineConfigPoolBuilder {\n100\t\tm.nodeSelector = ns\n101\t\treturn m\n102\t}\n103\t\n104\tfunc (m *MachineConfigPoolBuilder) WithMachineConfigSelector(mcs *metav1.LabelSelector) *MachineConfigPoolBuilder {\n105\t\tm.mcSelector = mcs\n106\t\treturn m\n107\t}\n108\t\n109\tfunc (m *MachineConfigPoolBuilder) MachineConfigPool() *mcfgv1.MachineConfigPool {\n110\t\tmcp := NewMachineConfigPool(m.name, m.mcSelector, m.nodeSelector, m.currentConfig)\n111\t\n112\t\tmcp.Spec.Paused = m.paused\n113\t\tmcp.Spec.MaxUnavailable = m.maxUnavailable\n114\t\n115\t\tif m.annos != nil {\n116\t\t\tif mcp.Annotations == nil {\n117\t\t\t\tmcp.Annotations = map[string]string{}\n118\t\t\t}\n119\t\n120\t\t\tfor k, v := range m.annos {\n121\t\t\t\tmcp.Annotations[k] = v\n122\t\t\t}\n123\t\t}\n124\t\n125\t\tif m.labels != nil {\n126\t\t\tif mcp.Labels == nil {\n127\t\t\t\tmcp.Labels = map[string]string{}\n128\t\t\t}\n129\t\n130\t\t\tfor k, v := range m.labels {\n131\t\t\t\tmcp.Labels[k] = v\n132\t\t\t}\n133\t\t}\n134\t\n135\t\tif m.conditions != nil {\n136\t\t\tfor _, condition := range m.conditions {\n137\t\t\t\tapihelpers.SetMachineConfigPoolCondition(&mcp.Status, *condition)\n138\t\t\t}\n139\t\t}\n140\t\n141\t\tif m.childConfigs != nil {\n142\t\t\tmcp.Spec.Configuration.Source = m.childConfigs\n143\t\t\tmcp.Status.Configuration.Source = m.childConfigs\n144\t\t}\n145\t\n146\t\treturn mcp\n147\t}\n148\t"}]},"parent_tool_use_id":"toolu_vrtx_01VmBJvAx2oNMkFPuwULsyHB","session_id":"2fe54bd0-271e-4b69-992f-525b199bb078","uuid":"a0df787b-8dc2-41b9-afca-a46d0e5e5403","timestamp":"2026-06-22T21:22:17.036Z","subagent_type":"Explore","task_description":"Find MachineConfigPool selector examples and logic"}
