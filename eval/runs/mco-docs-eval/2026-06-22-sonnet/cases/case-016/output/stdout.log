{"type": "assistant", "message": {"model": "claude-sonnet-4-6", "id": "msg_vrtx_01WB5eAnYkY6FmTp9WKj783E", "type": "message", "role": "assistant", "content": [{"type": "tool_use", "id": "toolu_vrtx_0174uGQekckQjjygMhdhB16a", "name": "Read", "input": {"file_path": "/home/jsuri/random-testing/prashanth-help/machine-config-operator/vendor/github.com/openshift/api/machineconfiguration/v1/types.go"}}], "stop_reason": null, "stop_sequence": null, "stop_details": null, "usage": {"input_tokens": 1, "cache_creation_input_tokens": 4523, "cache_read_input_tokens": 30275, "cache_creation": {"ephemeral_5m_input_tokens": 4523, "ephemeral_1h_input_tokens": 0}, "output_tokens": 24}, "context_management": null}, "parent_tool_use_id": "toolu_vrtx_01LvxZJ4Yutvn6tN8jjixSiJ", "session_id": "b36bfe9c-b5ba-4115-8f21-75f99f58dba6", "uuid": "ff5ce3e4-38cc-4231-9c27-4945c3f5c96d", "request_id": "req_vrtx_011CcK2ES7cNgQ5NUTFC5stY", "subagent_type": "Explore", "task_description": "Find MachineConfigPool and KubeletConfig examples and best practices", "timestamp": "2026-06-22T21:38:55.959Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_0174uGQekckQjjygMhdhB16a","type":"tool_result","content":"1\tpackage v1\n2\t\n3\timport (\n4\t\tconfigv1 \"github.com/openshift/api/config/v1\"\n5\t\tcorev1 \"k8s.io/api/core/v1\"\n6\t\t\"k8s.io/apimachinery/pkg/api/resource\"\n7\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n8\t\truntime \"k8s.io/apimachinery/pkg/runtime\"\n9\t\t\"k8s.io/apimachinery/pkg/util/intstr\"\n10\t)\n11\t\n12\t// MachineConfigRoleLabelKey is metadata key in the MachineConfig. Specifies the node role that config should be applied to.\n13\t// For example: `master` or `worker`\n14\tconst MachineConfigRoleLabelKey = \"machineconfiguration.openshift.io/role\"\n15\t\n16\t// KubeletConfigRoleLabelPrefix is the label that must be present in the KubeletConfig CR\n17\tconst KubeletConfigRoleLabelPrefix = \"pools.operator.machineconfiguration.openshift.io/\"\n18\t\n19\t// +genclient\n20\t// +genclient:nonNamespaced\n21\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n22\t// +kubebuilder:object:root=true\n23\t// +kubebuilder:resource:path=controllerconfigs,scope=Cluster\n24\t// +kubebuilder:subresource:status\n25\t// +openshift:api-approved.openshift.io=https://github.com/openshift/api/pull/1453\n26\t// +openshift:file-pattern=cvoRunLevel=0000_80,operatorName=machine-config,operatorOrdering=01\n27\t// +kubebuilder:metadata:labels=openshift.io/operator-managed=\n28\t\n29\t// ControllerConfig describes configuration for MachineConfigController.\n30\t// This is currently only used to drive the MachineConfig objects generated by the TemplateController.\n31\t//\n32\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n33\t// +openshift:compatibility-gen:level=1\n34\ttype ControllerConfig struct {\n35\t\tmetav1.TypeMeta   `json:\",inline\"`\n36\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n37\t\n38\t\t// TODO(jkyros): inconsistent historical generation resulted in the controllerconfig CRD being\n39\t\t// generated with all fields required, while everything else was generated with optional\n40\t\n41\t\t// spec contains the desired controller config configuration.\n42\t\t// +required\n43\t\tSpec ControllerConfigSpec `json:\"spec\"`\n44\t\n45\t\t// status contains observed information about the controller config.\n46\t\t// +optional\n47\t\tStatus ControllerConfigStatus `json:\"status\"`\n48\t}\n49\t\n50\t// ControllerConfigSpec is the spec for ControllerConfig resource.\n51\ttype ControllerConfigSpec struct {\n52\t\t// clusterDNSIP is the cluster DNS IP address\n53\t\t// +required\n54\t\tClusterDNSIP string `json:\"clusterDNSIP\"`\n55\t\n56\t\t// cloudProviderConfig is the configuration for the given cloud provider\n57\t\t// +required\n58\t\tCloudProviderConfig string `json:\"cloudProviderConfig\"`\n59\t\n60\t\t// platform is deprecated, use Infra.Status.PlatformStatus.Type instead\n61\t\t// +optional\n62\t\tPlatform string `json:\"platform,omitempty\"`\n63\t\n64\t\t// etcdDiscoveryDomain is deprecated, use Infra.Status.EtcdDiscoveryDomain instead\n65\t\t// +optional\n66\t\tEtcdDiscoveryDomain string `json:\"etcdDiscoveryDomain,omitempty\"`\n67\t\n68\t\t// TODO: Use string for CA data\n69\t\n70\t\t// kubeAPIServerServingCAData managed Kubelet to API Server Cert... Rotated automatically\n71\t\t// +required\n72\t\tKubeAPIServerServingCAData []byte `json:\"kubeAPIServerServingCAData\"`\n73\t\n74\t\t// rootCAData specifies the root CA data\n75\t\t// +required\n76\t\tRootCAData []byte `json:\"rootCAData\"`\n77\t\n78\t\t// cloudProviderCAData specifies the cloud provider CA data\n79\t\t// +required\n80\t\t// +nullable\n81\t\tCloudProviderCAData []byte `json:\"cloudProviderCAData\"`\n82\t\n83\t\t// additionalTrustBundle is a certificate bundle that will be added to the nodes\n84\t\t// trusted certificate store.\n85\t\t// +required\n86\t\t// +nullable\n87\t\tAdditionalTrustBundle []byte `json:\"additionalTrustBundle\"`\n88\t\n89\t\t// imageRegistryBundleUserData is Image Registry Data provided by the user\n90\t\t// +listType=atomic\n91\t\t// +optional\n92\t\tImageRegistryBundleUserData []ImageRegistryBundle `json:\"imageRegistryBundleUserData\"`\n93\t\n94\t\t// imageRegistryBundleData is the ImageRegistryData\n95\t\t// +listType=atomic\n96\t\t// +optional\n97\t\tImageRegistryBundleData []ImageRegistryBundle `json:\"imageRegistryBundleData\"`\n98\t\n99\t\t// TODO: Investigate using a ConfigMapNameReference for the PullSecret and OSImageURL\n100\t\n101\t\t// pullSecret is the default pull secret that needs to be installed\n102\t\t// on all machines.\n103\t\t// +optional\n104\t\tPullSecret *corev1.ObjectReference `json:\"pullSecret,omitempty\"`\n105\t\n106\t\t// internalRegistryPullSecret is the pull secret for the internal registry, used by\n107\t\t// rpm-ostree to pull images from the internal registry if present\n108\t\t// +optional\n109\t\t// +nullable\n110\t\tInternalRegistryPullSecret []byte `json:\"internalRegistryPullSecret\"`\n111\t\n112\t\t// images is map of images that are used by the controller to render templates under ./templates/\n113\t\t// +required\n114\t\tImages map[string]string `json:\"images\"`\n115\t\n116\t\t// baseOSContainerImage is the new-format container image for operating system updates.\n117\t\t// +required\n118\t\tBaseOSContainerImage string `json:\"baseOSContainerImage\"`\n119\t\n120\t\t// baseOSExtensionsContainerImage is the matching extensions container for the new-format container\n121\t\t// +optional\n122\t\tBaseOSExtensionsContainerImage string `json:\"baseOSExtensionsContainerImage\"`\n123\t\n124\t\t// osImageURL is the old-format container image that contains the OS update payload.\n125\t\t// +optional\n126\t\tOSImageURL string `json:\"osImageURL\"`\n127\t\n128\t\t// releaseImage is the image used when installing the cluster\n129\t\t// +required\n130\t\tReleaseImage string `json:\"releaseImage\"`\n131\t\n132\t\t// proxy holds the current proxy configuration for the nodes\n133\t\t// +required\n134\t\t// +nullable\n135\t\tProxy *configv1.ProxyStatus `json:\"proxy\"`\n136\t\n137\t\t// infra holds the infrastructure details\n138\t\t// +kubebuilder:validation:EmbeddedResource\n139\t\t// +required\n140\t\t// +nullable\n141\t\tInfra *configv1.Infrastructure `json:\"infra\"`\n142\t\n143\t\t// dns holds the cluster dns details\n144\t\t// +kubebuilder:validation:EmbeddedResource\n145\t\t// +required\n146\t\t// +nullable\n147\t\tDNS *configv1.DNS `json:\"dns\"`\n148\t\n149\t\t// ipFamilies indicates the IP families in use by the cluster network\n150\t\t// +required\n151\t\tIPFamilies IPFamiliesType `json:\"ipFamilies\"`\n152\t\n153\t\t// networkType holds the type of network the cluster is using\n154\t\t// XXX: this is temporary and will be dropped as soon as possible in favor of a better support\n155\t\t// to start network related services the proper way.\n156\t\t// Nobody is also changing this once the cluster is up and running the first time, so, disallow\n157\t\t// regeneration if this changes.\n158\t\t// +optional\n159\t\tNetworkType string `json:\"networkType,omitempty\"`\n160\t\n161\t\t// network contains additional network related information\n162\t\t// +required\n163\t\t// +nullable\n164\t\tNetwork *NetworkInfo `json:\"network\"`\n165\t}\n166\t\n167\t// ImageRegistryBundle contains information for writing image registry certificates\n168\ttype ImageRegistryBundle struct {\n169\t\t// file holds the name of the file where the bundle will be written to disk\n170\t\t// +required\n171\t\tFile string `json:\"file\"`\n172\t\t// data holds the contents of the bundle that will be written to the file location\n173\t\t// +required\n174\t\tData []byte `json:\"data\"`\n175\t}\n176\t\n177\t// IPFamiliesType indicates whether the cluster network is IPv4-only, IPv6-only, or dual-stack\n178\ttype IPFamiliesType string\n179\t\n180\tconst (\n181\t\tIPFamiliesIPv4                 IPFamiliesType = \"IPv4\"\n182\t\tIPFamiliesIPv6                 IPFamiliesType = \"IPv6\"\n183\t\tIPFamiliesDualStack            IPFamiliesType = \"DualStack\"\n184\t\tIPFamiliesDualStackIPv6Primary IPFamiliesType = \"DualStackIPv6Primary\"\n185\t)\n186\t\n187\t// Network contains network related configuration\n188\ttype NetworkInfo struct {\n189\t\t// mtuMigration contains the MTU migration configuration.\n190\t\t// +required\n191\t\t// +nullable\n192\t\tMTUMigration *configv1.MTUMigration `json:\"mtuMigration\"`\n193\t}\n194\t\n195\t// ControllerConfigStatus is the status for ControllerConfig\n196\ttype ControllerConfigStatus struct {\n197\t\t// observedGeneration represents the generation observed by the controller.\n198\t\t// +optional\n199\t\tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n200\t\n201\t\t// conditions represents the latest available observations of current state.\n202\t\t// +listType=map\n203\t\t// +listMapKey=type\n204\t\t// +optional\n205\t\tConditions []ControllerConfigStatusCondition `json:\"conditions\"`\n206\t\n207\t\t// controllerCertificates represents the latest available observations of the automatically rotating certificates in the MCO.\n208\t\t// +listType=atomic\n209\t\t// +optional\n210\t\tControllerCertificates []ControllerCertificate `json:\"controllerCertificates\"`\n211\t}\n212\t\n213\t// ControllerCertificate contains info about a specific cert.\n214\ttype ControllerCertificate struct {\n215\t\t// subject is the cert subject\n216\t\t// +required\n217\t\tSubject string `json:\"subject\"`\n218\t\n219\t\t// signer is the  cert Issuer\n220\t\t// +required\n221\t\tSigner string `json:\"signer\"`\n222\t\n223\t\t// notBefore is the lower boundary for validity\n224\t\t// +optional\n225\t\tNotBefore *metav1.Time `json:\"notBefore,omitempty\"`\n226\t\n227\t\t// notAfter is the upper boundary for validity\n228\t\t// +optional\n229\t\tNotAfter *metav1.Time `json:\"notAfter,omitempty\"`\n230\t\n231\t\t// bundleFile is the larger bundle a cert comes from\n232\t\t// +required\n233\t\tBundleFile string `json:\"bundleFile\"`\n234\t}\n235\t\n236\t// ControllerConfigStatusCondition contains condition information for ControllerConfigStatus\n237\ttype ControllerConfigStatusCondition struct {\n238\t\t// type specifies the state of the operator's reconciliation functionality.\n239\t\t// +required\n240\t\tType ControllerConfigStatusConditionType `json:\"type\"`\n241\t\n242\t\t// status of the condition, one of True, False, Unknown.\n243\t\t// +required\n244\t\tStatus corev1.ConditionStatus `json:\"status\"`\n245\t\n246\t\t// lastTransitionTime is the time of the last update to the current status object.\n247\t\t// +required\n248\t\t// +nullable\n249\t\tLastTransitionTime metav1.Time `json:\"lastTransitionTime\"`\n250\t\n251\t\t// reason is the reason for the condition's last transition.  Reasons are PascalCase\n252\t\t// +optional\n253\t\tReason string `json:\"reason,omitempty\"`\n254\t\n255\t\t// message provides additional information about the current condition.\n256\t\t// This is only to be consumed by humans.\n257\t\t// +optional\n258\t\tMessage string `json:\"message,omitempty\"`\n259\t}\n260\t\n261\t// ControllerConfigStatusConditionType valid conditions of a ControllerConfigStatus\n262\ttype ControllerConfigStatusConditionType string\n263\t\n264\tconst (\n265\t\t// TemplateControllerRunning means the template controller is currently running.\n266\t\tTemplateControllerRunning ControllerConfigStatusConditionType = \"TemplateControllerRunning\"\n267\t\n268\t\t// TemplateControllerCompleted means the template controller has completed reconciliation.\n269\t\tTemplateControllerCompleted ControllerConfigStatusConditionType = \"TemplateControllerCompleted\"\n270\t\n271\t\t// TemplateControllerFailing means the template controller is failing.\n272\t\tTemplateControllerFailing ControllerConfigStatusConditionType = \"TemplateControllerFailing\"\n273\t)\n274\t\n275\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n276\t\n277\t// ControllerConfigList is a list of ControllerConfig resources\n278\t//\n279\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n280\t// +openshift:compatibility-gen:level=1\n281\ttype ControllerConfigList struct {\n282\t\tmetav1.TypeMeta `json:\",inline\"`\n283\t\tmetav1.ListMeta `json:\"metadata\"`\n284\t\n285\t\tItems []ControllerConfig `json:\"items\"`\n286\t}\n287\t\n288\t// +genclient\n289\t// +genclient:noStatus\n290\t// +genclient:nonNamespaced\n291\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n292\t\n293\t// MachineConfig defines the configuration for a machine\n294\t//\n295\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n296\t// +kubebuilder:object:root=true\n297\t// +kubebuilder:resource:path=machineconfigs,scope=Cluster,shortName=mc\n298\t// +openshift:api-approved.openshift.io=https://github.com/openshift/api/pull/1453\n299\t// +openshift:file-pattern=cvoRunLevel=0000_80,operatorName=machine-config,operatorOrdering=01\n300\t// +kubebuilder:metadata:labels=\"openshift.io/operator-managed=\"\n301\t// +kubebuilder:printcolumn:name=GeneratedByController,JSONPath=.metadata.annotations.machineconfiguration\\.openshift\\.io/generated-by-controller-version,type=string,description=Version of the controller that generated the machineconfig. This will be empty if the machineconfig is not managed by a controller.\n302\t// +kubebuilder:printcolumn:name=IgnitionVersion,JSONPath=.spec.config.ignition.version,type=string,description=Version of the Ignition Config defined in the machineconfig.\n303\t// +kubebuilder:printcolumn:name=Age,JSONPath=.metadata.creationTimestamp,type=date\n304\t// +openshift:compatibility-gen:level=1\n305\ttype MachineConfig struct {\n306\t\tmetav1.TypeMeta   `json:\",inline\"`\n307\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n308\t\t// +optional\n309\t\tSpec MachineConfigSpec `json:\"spec\"`\n310\t}\n311\t\n312\t// MachineConfigSpec is the spec for MachineConfig\n313\ttype MachineConfigSpec struct {\n314\t\t// osImageURL specifies the remote location that will be used to\n315\t\t// fetch the OS.\n316\t\t// +optional\n317\t\tOSImageURL string `json:\"osImageURL\"`\n318\t\n319\t\t// baseOSExtensionsContainerImage specifies the remote location that will be used\n320\t\t// to fetch the extensions container matching a new-format OS image\n321\t\t// +optional\n322\t\tBaseOSExtensionsContainerImage string `json:\"baseOSExtensionsContainerImage\"`\n323\t\n324\t\t// config is a Ignition Config object.\n325\t\t// +optional\n326\t\tConfig runtime.RawExtension `json:\"config,omitempty\"`\n327\t\n328\t\t// kernelArguments contains a list of kernel arguments to be added\n329\t\t// +listType=atomic\n330\t\t// +nullable\n331\t\t// +optional\n332\t\tKernelArguments []string `json:\"kernelArguments\"`\n333\t\n334\t\t// extensions contains a list of additional features that can be enabled on host\n335\t\t// +listType=atomic\n336\t\t// +optional\n337\t\tExtensions []string `json:\"extensions\"`\n338\t\n339\t\t// fips controls FIPS mode\n340\t\t// +optional\n341\t\tFIPS bool `json:\"fips\"`\n342\t\n343\t\t// kernelType contains which kernel we want to be running like default\n344\t\t// (traditional), realtime, 64k-pages (aarch64 only).\n345\t\t// +optional\n346\t\tKernelType string `json:\"kernelType\"`\n347\t}\n348\t\n349\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n350\t\n351\t// MachineConfigList is a list of MachineConfig resources\n352\t//\n353\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n354\t// +openshift:compatibility-gen:level=1\n355\ttype MachineConfigList struct {\n356\t\tmetav1.TypeMeta `json:\",inline\"`\n357\t\tmetav1.ListMeta `json:\"metadata\"`\n358\t\n359\t\tItems []MachineConfig `json:\"items\"`\n360\t}\n361\t\n362\t// +genclient\n363\t// +genclient:nonNamespaced\n364\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n365\t\n366\t// MachineConfigPool describes a pool of MachineConfigs.\n367\t//\n368\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n369\t// +kubebuilder:object:root=true\n370\t// +kubebuilder:resource:path=machineconfigpools,scope=Cluster,shortName=mcp\n371\t// +kubebuilder:subresource:status\n372\t// +openshift:api-approved.openshift.io=https://github.com/openshift/api/pull/1453\n373\t// +openshift:file-pattern=cvoRunLevel=0000_80,operatorName=machine-config,operatorOrdering=01\n374\t// +kubebuilder:metadata:labels=\"openshift.io/operator-managed=\"\n375\t// +kubebuilder:printcolumn:name=Config,JSONPath=.status.configuration.name,type=string\n376\t// +kubebuilder:printcolumn:name=Updated,JSONPath=.status.conditions[?(@.type==\"Updated\")].status,type=string,description=When all the machines in the pool are updated to the correct machine config.\n377\t// +kubebuilder:printcolumn:name=Updating,JSONPath=.status.conditions[?(@.type==\"Updating\")].status,type=string,description=When at least one of machine is not either not updated or is in the process of updating to the desired machine config.\n378\t// +kubebuilder:printcolumn:name=Degraded,JSONPath=.status.conditions[?(@.type==\"Degraded\")].status,type=string,description=When progress is blocked on updating one or more nodes or the pool configuration is failing.\n379\t// +kubebuilder:printcolumn:name=MachineCount,JSONPath=.status.machineCount,type=number,description=Total number of machines in the machine config pool\n380\t// +kubebuilder:printcolumn:name=ReadyMachineCount,JSONPath=.status.readyMachineCount,type=number,description=Total number of ready machines targeted by the pool\n381\t// +kubebuilder:printcolumn:name=UpdatedMachineCount,JSONPath=.status.updatedMachineCount,type=number,description=Total number of machines targeted by the pool that have the CurrentMachineConfig as their config\n382\t// +kubebuilder:printcolumn:name=DegradedMachineCount,JSONPath=.status.degradedMachineCount,type=number,description=Total number of machines marked degraded (or unreconcilable)\n383\t// +kubebuilder:printcolumn:name=Age,JSONPath=.metadata.creationTimestamp,type=date\n384\t// +openshift:compatibility-gen:level=1\n385\ttype MachineConfigPool struct {\n386\t\tmetav1.TypeMeta   `json:\",inline\"`\n387\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n388\t\n389\t\t// spec contains the desired machine config pool configuration.\n390\t\t// +required\n391\t\tSpec MachineConfigPoolSpec `json:\"spec\"`\n392\t\n393\t\t// status contains observed information about the machine config pool.\n394\t\t// +optional\n395\t\tStatus MachineConfigPoolStatus `json:\"status\"`\n396\t}\n397\t\n398\t// MachineConfigPoolSpec is the spec for MachineConfigPool resource.\n399\ttype MachineConfigPoolSpec struct {\n400\t\t// machineConfigSelector specifies a label selector for MachineConfigs.\n401\t\t// Refer https://kubernetes.io/docs/concepts/overview/working-with-objects/labels/ on how label and selectors work.\n402\t\t// +optional\n403\t\tMachineConfigSelector *metav1.LabelSelector `json:\"machineConfigSelector,omitempty\"`\n404\t\n405\t\t// nodeSelector specifies a label selector for Machines\n406\t\t// +optional\n407\t\tNodeSelector *metav1.LabelSelector `json:\"nodeSelector,omitempty\"`\n408\t\n409\t\t// paused specifies whether or not changes to this machine config pool should be stopped.\n410\t\t// This includes generating new desiredMachineConfig and update of machines.\n411\t\t// +optional\n412\t\tPaused bool `json:\"paused\"`\n413\t\n414\t\t// maxUnavailable defines either an integer number or percentage\n415\t\t// of nodes in the pool that can go Unavailable during an update.\n416\t\t// This includes nodes Unavailable for any reason, including user\n417\t\t// initiated cordons, failing nodes, etc. The default value is 1.\n418\t\t//\n419\t\t// A value larger than 1 will mean multiple nodes going unavailable during\n420\t\t// the update, which may affect your workload stress on the remaining nodes.\n421\t\t// You cannot set this value to 0 to stop updates (it will default back to 1);\n422\t\t// to stop updates, use the 'paused' property instead. Drain will respect\n423\t\t// Pod Disruption Budgets (PDBs) such as etcd quorum guards, even if\n424\t\t// maxUnavailable is greater than one.\n425\t\t// +optional\n426\t\tMaxUnavailable *intstr.IntOrString `json:\"maxUnavailable,omitempty\"`\n427\t\n428\t\t// The targeted MachineConfig object for the machine config pool.\n429\t\t// +optional\n430\t\tConfiguration MachineConfigPoolStatusConfiguration `json:\"configuration\"`\n431\t\n432\t\t// pinnedImageSets specifies a sequence of PinnedImageSetRef objects for the\n433\t\t// pool. Nodes within this pool will preload and pin images defined in the\n434\t\t// PinnedImageSet. Before pulling images the MachineConfigDaemon will ensure\n435\t\t// the total uncompressed size of all the images does not exceed available\n436\t\t// resources. If the total size of the images exceeds the available\n437\t\t// resources the controller will report a Degraded status to the\n438\t\t// MachineConfigPool and not attempt to pull any images. Also to help ensure\n439\t\t// the kubelet can mitigate storage risk, the pinned_image configuration and\n440\t\t// subsequent service reload will happen only after all of the images have\n441\t\t// been pulled for each set. Images from multiple PinnedImageSets are loaded\n442\t\t// and pinned sequentially as listed. Duplicate and existing images will be\n443\t\t// skipped.\n444\t\t//\n445\t\t// Any failure to prefetch or pin images will result in a Degraded pool.\n446\t\t// Resolving these failures is the responsibility of the user. The admin\n447\t\t// should be proactive in ensuring adequate storage and proper image\n448\t\t// authentication exists in advance.\n449\t\t// +optional\n450\t\t// +listType=map\n451\t\t// +listMapKey=name\n452\t\t// +kubebuilder:validation:MaxItems=100\n453\t\tPinnedImageSets []PinnedImageSetRef `json:\"pinnedImageSets,omitempty\"`\n454\t\n455\t\t// osImageStream specifies an OS stream to be used for the pool.\n456\t\t//\n457\t\t// This field can be optionally set to a known OSImageStream name to change the\n458\t\t// OS and Extension images with a well-known, tested, release-provided set of images.\n459\t\t// This enables a streamlined way of switching the pool's node OS to a different version\n460\t\t// than the cluster default, such as transitioning to a major RHEL version.\n461\t\t//\n462\t\t// When set, the referenced stream overrides the cluster-wide OS\n463\t\t// images for the pool with the OS and Extensions associated to stream.\n464\t\t// When omitted, the pool uses the cluster-wide default OS images.\n465\t\t//\n466\t\t// +openshift:enable:FeatureGate=OSStreams\n467\t\t// +optional\n468\t\tOSImageStream OSImageStreamReference `json:\"osImageStream,omitempty,omitzero\"`\n469\t}\n470\t\n471\ttype OSImageStreamReference struct {\n472\t\t// name is a required reference to an OSImageStream to be used for the pool.\n473\t\t//\n474\t\t// It must be a valid RFC 1123 subdomain between 1 and 253 characters in length,\n475\t\t// consisting of lowercase alphanumeric characters, hyphens ('-'), and periods ('.').\n476\t\t//\n477\t\t// +required\n478\t\t// +kubebuilder:validation:MinLength=1\n479\t\t// +kubebuilder:validation:MaxLength=253\n480\t\t// +kubebuilder:validation:XValidation:rule=\"!format.dns1123Subdomain().validate(self).hasValue()\",message=\"a RFC 1123 subdomain must consist of lower case alphanumeric characters, '-' or '.', and must start and end with an alphanumeric character.\"\n481\t\tName string `json:\"name,omitempty\"`\n482\t}\n483\t\n484\ttype PinnedImageSetRef struct {\n485\t\t// name is a reference to the name of a PinnedImageSet.  Must adhere to\n486\t\t// RFC-1123 (https://tools.ietf.org/html/rfc1123).\n487\t\t// Made up of one of more period-separated (.) segments, where each segment\n488\t\t// consists of alphanumeric characters and hyphens (-), must begin and end\n489\t\t// with an alphanumeric character, and is at most 63 characters in length.\n490\t\t// The total length of the name must not exceed 253 characters.\n491\t\t// +kubebuilder:validation:MinLength=1\n492\t\t// +kubebuilder:validation:MaxLength=253\n493\t\t// +kubebuilder:validation:Pattern=`^([a-zA-Z0-9]|[a-zA-Z0-9][a-zA-Z0-9\\-]{0,61}[a-zA-Z0-9])(\\.([a-zA-Z0-9]|[a-zA-Z0-9][a-zA-Z0-9\\-]{0,61}[a-zA-Z0-9]))*$`\n494\t\t// +required\n495\t\tName string `json:\"name\"`\n496\t}\n497\t\n498\t// MachineConfigPoolStatus is the status for MachineConfigPool resource.\n499\ttype MachineConfigPoolStatus struct {\n500\t\t// observedGeneration represents the generation observed by the controller.\n501\t\t// +optional\n502\t\tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n503\t\n504\t\t// configuration represents the current MachineConfig object for the machine config pool.\n505\t\t// +optional\n506\t\tConfiguration MachineConfigPoolStatusConfiguration `json:\"configuration\"`\n507\t\n508\t\t// machineCount represents the total number of machines in the machine config pool.\n509\t\t// +optional\n510\t\tMachineCount int32 `json:\"machineCount\"`\n511\t\n512\t\t// updatedMachineCount represents the total number of machines targeted by the pool that have the CurrentMachineConfig as their config.\n513\t\t// +optional\n514\t\tUpdatedMachineCount int32 `json:\"updatedMachineCount\"`\n515\t\n516\t\t// readyMachineCount represents the total number of ready machines targeted by the pool.\n517\t\t// +optional\n518\t\tReadyMachineCount int32 `json:\"readyMachineCount\"`\n519\t\n520\t\t// unavailableMachineCount represents the total number of unavailable (non-ready) machines targeted by the pool.\n521\t\t// A node is marked unavailable if it is in updating state or NodeReady condition is false.\n522\t\t// +optional\n523\t\tUnavailableMachineCount int32 `json:\"unavailableMachineCount\"`\n524\t\n525\t\t// degradedMachineCount represents the total number of machines marked degraded (or unreconcilable).\n526\t\t// A node is marked degraded if applying a configuration failed..\n527\t\t// +optional\n528\t\tDegradedMachineCount int32 `json:\"degradedMachineCount\"`\n529\t\n530\t\t// conditions represents the latest available observations of current state.\n531\t\t// +listType=atomic\n532\t\t// +optional\n533\t\tConditions []MachineConfigPoolCondition `json:\"conditions\"`\n534\t\n535\t\t// certExpirys keeps track of important certificate expiration data\n536\t\t// +listType=atomic\n537\t\t// +optional\n538\t\tCertExpirys []CertExpiry `json:\"certExpirys\"`\n539\t\n540\t\t// poolSynchronizersStatus is the status of the machines managed by the pool synchronizers.\n541\t\t// +listType=map\n542\t\t// +listMapKey=poolSynchronizerType\n543\t\t// +optional\n544\t\tPoolSynchronizersStatus []PoolSynchronizerStatus `json:\"poolSynchronizersStatus,omitempty\"`\n545\t\n546\t\t// osImageStream specifies the last updated OSImageStream for the pool.\n547\t\t//\n548\t\t// When omitted, the pool is using the cluster-wide default OS images.\n549\t\t// +openshift:enable:FeatureGate=OSStreams\n550\t\t// +optional\n551\t\tOSImageStream OSImageStreamReference `json:\"osImageStream,omitempty,omitzero\"`\n552\t}\n553\t\n554\t// +kubebuilder:validation:XValidation:rule=\"self.machineCount >= self.updatedMachineCount\", message=\"machineCount must be greater than or equal to updatedMachineCount\"\n555\t// +kubebuilder:validation:XValidation:rule=\"self.machineCount >= self.availableMachineCount\", message=\"machineCount must be greater than or equal to availableMachineCount\"\n556\t// +kubebuilder:validation:XValidation:rule=\"self.machineCount >= self.unavailableMachineCount\", message=\"machineCount must be greater than or equal to unavailableMachineCount\"\n557\t// +kubebuilder:validation:XValidation:rule=\"self.machineCount >= self.readyMachineCount\", message=\"machineCount must be greater than or equal to readyMachineCount\"\n558\t// +kubebuilder:validation:XValidation:rule=\"self.availableMachineCount >= self.readyMachineCount\", message=\"availableMachineCount must be greater than or equal to readyMachineCount\"\n559\ttype PoolSynchronizerStatus struct {\n560\t\t// poolSynchronizerType describes the type of the pool synchronizer.\n561\t\t// +required\n562\t\tPoolSynchronizerType PoolSynchronizerType `json:\"poolSynchronizerType\"`\n563\t\t// machineCount is the number of machines that are managed by the node synchronizer.\n564\t\t// +required\n565\t\t// +kubebuilder:validation:Minimum=0\n566\t\tMachineCount int64 `json:\"machineCount\"`\n567\t\t// updatedMachineCount is the number of machines that have been updated by the node synchronizer.\n568\t\t// +required\n569\t\t// +kubebuilder:validation:Minimum=0\n570\t\tUpdatedMachineCount int64 `json:\"updatedMachineCount\"`\n571\t\t// readyMachineCount is the number of machines managed by the node synchronizer that are in a ready state.\n572\t\t// +required\n573\t\t// +kubebuilder:validation:Minimum=0\n574\t\tReadyMachineCount int64 `json:\"readyMachineCount\"`\n575\t\t// availableMachineCount is the number of machines managed by the node synchronizer which are available.\n576\t\t// +required\n577\t\t// +kubebuilder:validation:Minimum=0\n578\t\tAvailableMachineCount int64 `json:\"availableMachineCount\"`\n579\t\t// unavailableMachineCount is the number of machines managed by the node synchronizer but are unavailable.\n580\t\t// +required\n581\t\t// +kubebuilder:validation:Minimum=0\n582\t\tUnavailableMachineCount int64 `json:\"unavailableMachineCount\"`\n583\t\t// +kubebuilder:validation:XValidation:rule=\"self >= oldSelf || (self == 0 && oldSelf > 0)\", message=\"observedGeneration must not move backwards except to zero\"\n584\t\t// observedGeneration is the last generation change that has been applied.\n585\t\t// +kubebuilder:validation:Minimum=0\n586\t\t// +optional\n587\t\tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n588\t}\n589\t\n590\t// PoolSynchronizerType is an enum that describe the type of pool synchronizer. A pool synchronizer is a one or more controllers that\n591\t// manages the on disk state of a set of machines within a pool.\n592\t// +kubebuilder:validation:Enum:=\"PinnedImageSets\"\n593\t// +kubebuilder:validation:MaxLength=256\n594\ttype PoolSynchronizerType string\n595\t\n596\tconst (\n597\t\t// PinnedImageSets represents a pool synchronizer for pinned image sets.\n598\t\tPinnedImageSets PoolSynchronizerType = \"PinnedImageSets\"\n599\t)\n600\t\n601\t// ceryExpiry contains the bundle name and the expiry date\n602\ttype CertExpiry struct {\n603\t\t// bundle is the name of the bundle in which the subject certificate resides\n604\t\t// +required\n605\t\tBundle string `json:\"bundle\"`\n606\t\t// subject is the subject of the certificate\n607\t\t// +required\n608\t\tSubject string `json:\"subject\"`\n609\t\t// expiry is the date after which the certificate will no longer be valid\n610\t\t// +optional\n611\t\tExpiry *metav1.Time `json:\"expiry\"`\n612\t}\n613\t\n614\t// MachineConfigPoolStatusConfiguration stores the current configuration for the pool, and\n615\t// optionally also stores the list of MachineConfig objects used to generate the configuration.\n616\ttype MachineConfigPoolStatusConfiguration struct {\n617\t\tcorev1.ObjectReference `json:\",inline\"`\n618\t\n619\t\t// source is the list of MachineConfig objects that were used to generate the single MachineConfig object specified in `content`.\n620\t\t// +listType=atomic\n621\t\t// +optional\n622\t\tSource []corev1.ObjectReference `json:\"source,omitempty\"`\n623\t}\n624\t\n625\t// MachineConfigPoolCondition contains condition information for an MachineConfigPool.\n626\ttype MachineConfigPoolCondition struct {\n627\t\t// type of the condition, currently ('Done', 'Updating', 'Failed').\n628\t\t// +optional\n629\t\tType MachineConfigPoolConditionType `json:\"type\"`\n630\t\n631\t\t// status of the condition, one of ('True', 'False', 'Unknown').\n632\t\t// +optional\n633\t\tStatus corev1.ConditionStatus `json:\"status,omitempty\"`\n634\t\n635\t\t// lastTransitionTime is the timestamp corresponding to the last status\n636\t\t// change of this condition.\n637\t\t// +nullable\n638\t\t// +optional\n639\t\tLastTransitionTime metav1.Time `json:\"lastTransitionTime\"`\n640\t\n641\t\t// reason is a brief machine readable explanation for the condition's last\n642\t\t// transition.\n643\t\t// +optional\n644\t\tReason string `json:\"reason\"`\n645\t\n646\t\t// message is a human readable description of the details of the last\n647\t\t// transition, complementing reason.\n648\t\t// +optional\n649\t\tMessage string `json:\"message\"`\n650\t}\n651\t\n652\t// MachineConfigPoolConditionType valid conditions of a MachineConfigPool\n653\ttype MachineConfigPoolConditionType string\n654\t\n655\tconst (\n656\t\t// MachineConfigPoolUpdated means MachineConfigPool is updated completely.\n657\t\t// When the all the machines in the pool are updated to the correct machine config.\n658\t\tMachineConfigPoolUpdated MachineConfigPoolConditionType = \"Updated\"\n659\t\n660\t\t// MachineConfigPoolUpdating means MachineConfigPool is updating.\n661\t\t// When at least one of machine is not either not updated or is in the process of updating\n662\t\t// to the desired machine config.\n663\t\tMachineConfigPoolUpdating MachineConfigPoolConditionType = \"Updating\"\n664\t\n665\t\t// MachineConfigPoolNodeDegraded means the update for one of the machine is not progressing\n666\t\tMachineConfigPoolNodeDegraded MachineConfigPoolConditionType = \"NodeDegraded\"\n667\t\n668\t\t// MachineConfigPoolRenderDegraded means the rendered configuration for the pool cannot be generated because of an error\n669\t\tMachineConfigPoolRenderDegraded MachineConfigPoolConditionType = \"RenderDegraded\"\n670\t\n671\t\t// MachineConfigPoolImageBuildDegraded means the image build for the pool was not successful\n672\t\t// This condition is only used when Image Mode is enabled for the pool\n673\t\tMachineConfigPoolImageBuildDegraded MachineConfigPoolConditionType = \"ImageBuildDegraded\"\n674\t\n675\t\t// MachineConfigPoolPinnedImageSetsDegraded means the pinned image sets for the pool cannot be populated because of an error\n676\t\tMachineConfigPoolPinnedImageSetsDegraded MachineConfigPoolConditionType = \"PinnedImageSetsDegraded\"\n677\t\n678\t\t// MachineConfigPoolSynchronizerDegraded means the pool synchronizer can not be updated because of an error\n679\t\tMachineConfigPoolSynchronizerDegraded MachineConfigPoolConditionType = \"PoolSynchronizerDegraded\"\n680\t\n681\t\t// MachineConfigPoolDegraded is the overall status of the pool based, today, on whether we fail with NodeDegraded, RenderDegraded, or ImageBuildDegraded\n682\t\tMachineConfigPoolDegraded MachineConfigPoolConditionType = \"Degraded\"\n683\t\n684\t\tMachineConfigPoolBuildPending MachineConfigPoolConditionType = \"BuildPending\"\n685\t\n686\t\tMachineConfigPoolBuilding MachineConfigPoolConditionType = \"Building\"\n687\t\n688\t\tMachineConfigPoolBuildSuccess MachineConfigPoolConditionType = \"BuildSuccess\"\n689\t\n690\t\tMachineConfigPoolBuildFailed MachineConfigPoolConditionType = \"BuildFailed\"\n691\t\n692\t\tMachineConfigPoolBuildInterrupted MachineConfigPoolConditionType = \"BuildInterrupted\"\n693\t)\n694\t\n695\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n696\t\n697\t// MachineConfigPoolList is a list of MachineConfigPool resources\n698\t//\n699\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n700\t// +openshift:compatibility-gen:level=1\n701\ttype MachineConfigPoolList struct {\n702\t\tmetav1.TypeMeta `json:\",inline\"`\n703\t\tmetav1.ListMeta `json:\"metadata\"`\n704\t\n705\t\tItems []MachineConfigPool `json:\"items\"`\n706\t}\n707\t\n708\t// +genclient\n709\t// +genclient:nonNamespaced\n710\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n711\t\n712\t// KubeletConfig describes a customized Kubelet configuration.\n713\t//\n714\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n715\t// +kubebuilder:object:root=true\n716\t// +kubebuilder:resource:path=kubeletconfigs,scope=Cluster\n717\t// +kubebuilder:subresource:status\n718\t// +openshift:api-approved.openshift.io=https://github.com/openshift/api/pull/1453\n719\t// +openshift:file-pattern=cvoRunLevel=0000_80,operatorName=machine-config,operatorOrdering=01\n720\t// +kubebuilder:metadata:labels=\"openshift.io/operator-managed=\"\n721\t// +openshift:compatibility-gen:level=1\n722\ttype KubeletConfig struct {\n723\t\tmetav1.TypeMeta   `json:\",inline\"`\n724\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n725\t\n726\t\t// spec contains the desired kubelet configuration.\n727\t\t// +required\n728\t\tSpec KubeletConfigSpec `json:\"spec\"`\n729\t\n730\t\t// status contains observed information about the kubelet configuration.\n731\t\t// +optional\n732\t\tStatus KubeletConfigStatus `json:\"status\"`\n733\t}\n734\t\n735\t// KubeletConfigSpec configures the kubelet running on cluster nodes.\n736\ttype KubeletConfigSpec struct {\n737\t\t// autoSizingReserved controls whether system-reserved CPU and memory are automatically\n738\t\t// calculated based on each node's installed capacity. When set to true, this prevents node failure\n739\t\t// from resource starvation of system components (kubelet, CRI-O) without manual configuration.\n740\t\t// When omitted, this means the user has no opinion and the platform is left to choose a reasonable default,\n741\t\t// which is subject to change over time. The current default is true for worker nodes and false for control plane nodes.\n742\t\t// When set to false, automatic resource reservation is disabled and manual settings must be configured.\n743\t\t// +optional\n744\t\tAutoSizingReserved *bool `json:\"autoSizingReserved,omitempty\"`\n745\t\t// logLevel sets the kubelet log verbosity, controlling the amount of detail in kubelet logs.\n746\t\t// Valid values range from 0 (minimal logging) to 10 (maximum verbosity with trace-level detail).\n747\t\t// Higher log levels may impact node performance. When omitted, the platform chooses a reasonable default,\n748\t\t// which is subject to change over time. The current default is 2 (standard informational logging).\n749\t\t// +kubebuilder:validation:Minimum=0\n750\t\t// +kubebuilder:validation:Maximum=10\n751\t\t// +optional\n752\t\tLogLevel *int32 `json:\"logLevel,omitempty\"`\n753\t\n754\t\t// machineConfigPoolSelector selects which pools the KubeletConfig should apply to.\n755\t\t// When omitted or set to an empty selector {}, no pools are selected, which is equivalent\n756\t\t// to not matching any MachineConfigPool.\n757\t\t// +optional\n758\t\tMachineConfigPoolSelector *metav1.LabelSelector `json:\"machineConfigPoolSelector,omitempty\"`\n759\t\t// kubeletConfig contains upstream Kubernetes kubelet configuration fields.\n760\t\t// Values are validated by the kubelet itself. Invalid values may render nodes unusable.\n761\t\t// Refer to OpenShift documentation for the Kubernetes version corresponding to your\n762\t\t// OpenShift release to find valid kubelet configuration options.\n763\t\t// +optional\n764\t\tKubeletConfig *runtime.RawExtension `json:\"kubeletConfig,omitempty\"`\n765\t\n766\t\t// tlsSecurityProfile configures TLS settings for the kubelet.\n767\t\t// When omitted, the TLS configuration defaults to the value from apiservers.config.openshift.io/cluster.\n768\t\t// When specified, the type field can be set to either \"Old\", \"Intermediate\", \"Modern\", \"Custom\" or omitted for backward compatibility.\n769\t\t// +optional\n770\t\tTLSSecurityProfile *configv1.TLSSecurityProfile `json:\"tlsSecurityProfile,omitempty\"`\n771\t}\n772\t\n773\t// KubeletConfigStatus defines the observed state of a KubeletConfig\n774\ttype KubeletConfigStatus struct {\n775\t\t// observedGeneration represents the generation observed by the controller.\n776\t\t// +optional\n777\t\tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n778\t\n779\t\t// conditions represents the latest available observations of current state.\n780\t\t// +optional\n781\t\t// +listType=atomic\n782\t\tConditions []KubeletConfigCondition `json:\"conditions\"`\n783\t}\n784\t\n785\t// KubeletConfigCondition defines the state of the KubeletConfig\n786\ttype KubeletConfigCondition struct {\n787\t\t// type specifies the state of the operator's reconciliation functionality.\n788\t\t// +optional\n789\t\tType KubeletConfigStatusConditionType `json:\"type\"`\n790\t\n791\t\t// status of the condition, one of True, False, Unknown.\n792\t\t// +optional\n793\t\tStatus corev1.ConditionStatus `json:\"status,omitempty\"`\n794\t\n795\t\t// lastTransitionTime is the time of the last update to the current status object.\n796\t\t// +optional\n797\t\t// +nullable\n798\t\tLastTransitionTime metav1.Time `json:\"lastTransitionTime\"`\n799\t\n800\t\t// reason is the reason for the condition's last transition.  Reasons are PascalCase\n801\t\t// +optional\n802\t\tReason string `json:\"reason,omitempty\"`\n803\t\n804\t\t// message provides additional information about the current condition.\n805\t\t// This is only to be consumed by humans.\n806\t\t// +optional\n807\t\tMessage string `json:\"message,omitempty\"`\n808\t}\n809\t\n810\t// KubeletConfigStatusConditionType is the state of the operator's reconciliation functionality.\n811\ttype KubeletConfigStatusConditionType string\n812\t\n813\tconst (\n814\t\t// KubeletConfigSuccess designates a successful application of a KubeletConfig CR.\n815\t\tKubeletConfigSuccess KubeletConfigStatusConditionType = \"Success\"\n816\t\n817\t\t// KubeletConfigFailure designates a failure applying a KubeletConfig CR.\n818\t\tKubeletConfigFailure KubeletConfigStatusConditionType = \"Failure\"\n819\t)\n820\t\n821\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n822\t\n823\t// KubeletConfigList is a list of KubeletConfig resources\n824\t//\n825\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n826\t// +openshift:compatibility-gen:level=1\n827\ttype KubeletConfigList struct {\n828\t\tmetav1.TypeMeta `json:\",inline\"`\n829\t\tmetav1.ListMeta `json:\"metadata\"`\n830\t\n831\t\tItems []KubeletConfig `json:\"items\"`\n832\t}\n833\t\n834\t// +genclient\n835\t// +genclient:nonNamespaced\n836\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n837\t\n838\t// ContainerRuntimeConfig describes a customized Container Runtime configuration.\n839\t//\n840\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n841\t// +kubebuilder:object:root=true\n842\t// +kubebuilder:resource:path=containerruntimeconfigs,scope=Cluster,shortName=ctrcfg\n843\t// +kubebuilder:subresource:status\n844\t// +openshift:api-approved.openshift.io=https://github.com/openshift/api/pull/1453\n845\t// +openshift:file-pattern=cvoRunLevel=0000_80,operatorName=machine-config,operatorOrdering=01\n846\t// +kubebuilder:metadata:labels=\"openshift.io/operator-managed=\"\n847\t// +openshift:compatibility-gen:level=1\n848\ttype ContainerRuntimeConfig struct {\n849\t\tmetav1.TypeMeta   `json:\",inline\"`\n850\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n851\t\n852\t\t// spec contains the desired container runtime configuration.\n853\t\t// +required\n854\t\tSpec ContainerRuntimeConfigSpec `json:\"spec\"`\n855\t\n856\t\t// status contains observed information about the container runtime configuration.\n857\t\t// +optional\n858\t\tStatus ContainerRuntimeConfigStatus `json:\"status\"`\n859\t}\n860\t\n861\t// ContainerRuntimeConfigSpec defines the desired state of ContainerRuntimeConfig\n862\ttype ContainerRuntimeConfigSpec struct {\n863\t\t// machineConfigPoolSelector selects which pools the ContainerRuntimeConfig shoud apply to.\n864\t\t// A nil selector will result in no pools being selected.\n865\t\t// +optional\n866\t\tMachineConfigPoolSelector *metav1.LabelSelector `json:\"machineConfigPoolSelector,omitempty\"`\n867\t\n868\t\t// containerRuntimeConfig defines the tuneables of the container runtime.\n869\t\t// +required\n870\t\tContainerRuntimeConfig *ContainerRuntimeConfiguration `json:\"containerRuntimeConfig,omitempty\"`\n871\t}\n872\t\n873\t// ContainerRuntimeConfiguration defines the tuneables of the container runtime\n874\ttype ContainerRuntimeConfiguration struct {\n875\t\t// pidsLimit specifies the maximum number of processes allowed in a container\n876\t\t// +optional\n877\t\tPidsLimit *int64 `json:\"pidsLimit,omitempty\"`\n878\t\n879\t\t// logLevel specifies the verbosity of the logs based on the level it is set to.\n880\t\t// Options are fatal, panic, error, warn, info, and debug.\n881\t\t// +optional\n882\t\tLogLevel string `json:\"logLevel,omitempty\"`\n883\t\n884\t\t// logSizeMax specifies the Maximum size allowed for the container log file.\n885\t\t// Negative numbers indicate that no size limit is imposed.\n886\t\t// If it is positive, it must be >= 8192 to match/exceed conmon's read buffer.\n887\t\t// +optional\n888\t\tLogSizeMax *resource.Quantity `json:\"logSizeMax,omitempty\"`\n889\t\n890\t\t// overlaySize specifies the maximum size of a container image.\n891\t\t// This flag can be used to set quota on the size of container images. (default: 10GB)\n892\t\t// +optional\n893\t\tOverlaySize *resource.Quantity `json:\"overlaySize,omitempty\"`\n894\t\n895\t\t// defaultRuntime is the name of the OCI runtime to be used as the default for containers.\n896\t\t// Allowed values are `runc` and `crun`.\n897\t\t// When set to `runc`, OpenShift will use runc to execute the container\n898\t\t// When set to `crun`, OpenShift will use crun to execute the container\n899\t\t// When omitted, this means no opinion and the platform is left to choose a reasonable default,\n900\t\t// which is subject to change over time. Currently, the default is `crun`.\n901\t\t// +kubebuilder:validation:Enum=crun;runc\n902\t\t// +optional\n903\t\tDefaultRuntime ContainerRuntimeDefaultRuntime `json:\"defaultRuntime,omitempty\"`\n904\t\n905\t\t// additionalLayerStores configures additional read-only container image layer store locations for Open Container Initiative (OCI) images.\n906\t\t//\n907\t\t// Layers are checked in order: additional stores first, then the default location.\n908\t\t// Stores are read-only.\n909\t\t// Maximum of 5 stores allowed.\n910\t\t// Each path must be unique.\n911\t\t//\n912\t\t// When omitted, only the default layer location is used.\n913\t\t// When specified, at least one store must be provided.\n914\t\t//\n915\t\t// +openshift:enable:FeatureGate=AdditionalStorageConfig\n916\t\t// +optional\n917\t\t// +listType=atomic\n918\t\t// +kubebuilder:validation:MinItems=1\n919\t\t// +kubebuilder:validation:MaxItems=5\n920\t\t// +kubebuilder:validation:XValidation:rule=\"self.all(x, self.exists_one(y, x.path == y.path))\",message=\"additionalLayerStores must not contain duplicate paths\"\n921\t\tAdditionalLayerStores []AdditionalLayerStore `json:\"additionalLayerStores,omitempty\"`\n922\t\n923\t\t// additionalImageStores configures additional read-only container image store locations for Open Container Initiative (OCI) images.\n924\t\t//\n925\t\t// Images are checked in order: additional stores first, then the default location.\n926\t\t// Stores are read-only.\n927\t\t// Maximum of 10 stores allowed.\n928\t\t// Each path must be unique.\n929\t\t//\n930\t\t// When omitted, only the default image location is used.\n931\t\t// When specified, at least one store must be provided.\n932\t\t//\n933\t\t// +openshift:enable:FeatureGate=AdditionalStorageConfig\n934\t\t// +optional\n935\t\t// +listType=atomic\n936\t\t// +kubebuilder:validation:MinItems=1\n937\t\t// +kubebuilder:validation:MaxItems=10\n938\t\t// +kubebuilder:validation:XValidation:rule=\"self.all(x, self.exists_one(y, x.path == y.path))\",message=\"additionalImageStores must not contain duplicate paths\"\n939\t\tAdditionalImageStores []AdditionalImageStore `json:\"additionalImageStores,omitempty\"`\n940\t\n941\t\t// additionalArtifactStores configures additional read-only artifact storage locations for Open Container Initiative (OCI) artifacts.\n942\t\t//\n943\t\t// Artifacts are checked in order: additional stores first, then the default location (/var/lib/containers/storage/artifacts).\n944\t\t// Stores are read-only.\n945\t\t// Maximum of 10 stores allowed.\n946\t\t// Each path must be unique.\n947\t\t//\n948\t\t// When omitted, only the default artifact location is used.\n949\t\t// When specified, at least one store must be provided.\n950\t\t//\n951\t\t// +openshift:enable:FeatureGate=AdditionalStorageConfig\n952\t\t// +optional\n953\t\t// +listType=atomic\n954\t\t// +kubebuilder:validation:MinItems=1\n955\t\t// +kubebuilder:validation:MaxItems=10\n956\t\t// +kubebuilder:validation:XValidation:rule=\"self.all(x, self.exists_one(y, x.path == y.path))\",message=\"additionalArtifactStores must not contain duplicate paths\"\n957\t\tAdditionalArtifactStores []AdditionalArtifactStore `json:\"additionalArtifactStores,omitempty\"`\n958\t}\n959\t\n960\ttype ContainerRuntimeDefaultRuntime string\n961\t\n962\t// These constants are used in the Machine Config Operator (MCO)\n963\tconst (\n964\t\tContainerRuntimeDefaultRuntimeEmpty   = \"\"\n965\t\tContainerRuntimeDefaultRuntimeRunc    = \"runc\"\n966\t\tContainerRuntimeDefaultRuntimeCrun    = \"crun\"\n967\t\tContainerRuntimeDefaultRuntimeDefault = ContainerRuntimeDefaultRuntimeCrun\n968\t)\n969\t\n970\t// StorePath is an absolute filesystem path used by additional container storage configurations.\n971\t// The path must be between 1 and 256 characters long, begin with a forward slash, and only contain\n972\t// the characters a-z, A-Z, 0-9, '/', '.', '_', and '-'. Consecutive forward slashes are not permitted.\n973\t// +kubebuilder:validation:MinLength=1\n974\t// +kubebuilder:validation:MaxLength=256\n975\t// +kubebuilder:validation:XValidation:rule=\"self.matches('^/[a-zA-Z0-9/._-]+$')\",message=\"path must be absolute and contain only alphanumeric characters, '/', '.', '_', and '-'\"\n976\t// +kubebuilder:validation:XValidation:rule=\"!self.contains('//')\",message=\"path must not contain consecutive forward slashes\"\n977\ttype StorePath string\n978\t\n979\t// AdditionalLayerStore defines a read-only storage location for Open Container Initiative (OCI) container image layers.\n980\ttype AdditionalLayerStore struct {\n981\t\t// path specifies the absolute location of the additional layer store.\n982\t\t// The path must exist on the node before configuration is applied.\n983\t\t// When a container image is requested, layers found at this location will be used instead of\n984\t\t// retrieving from the registry.\n985\t\t// The path is required and must be between 1 and 256 characters long, begin with a forward slash,\n986\t\t// and only contain the characters a-z, A-Z, 0-9, '/', '.', '_', and '-'.\n987\t\t// Consecutive forward slashes are not permitted.\n988\t\t// +required\n989\t\tPath StorePath `json:\"path,omitempty\"`\n990\t}\n991\t\n992\t// AdditionalImageStore defines an additional read-only storage location for Open Container Initiative (OCI) images.\n993\ttype AdditionalImageStore struct {\n994\t\t// path specifies the absolute location of the additional image store.\n995\t\t// The path must exist on the node before configuration is applied.\n996\t\t// When a container image is requested, images found at this location will be used instead of\n997\t\t// retrieving from the registry.\n998\t\t// The path is required and must be between 1 and 256 characters long, begin with a forward slash,\n999\t\t// and only contain the characters a-z, A-Z, 0-9, '/', '.', '_', and '-'.\n1000\t\t// Consecutive forward slashes are not permitted.\n1001\t\t// +required\n1002\t\tPath StorePath `json:\"path,omitempty\"`\n1003\t}\n1004\t\n1005\t// AdditionalArtifactStore defines an additional read-only storage location for Open Container Initiative (OCI) artifacts.\n1006\ttype AdditionalArtifactStore struct {\n1007\t\t// path specifies the absolute location of the additional artifact store.\n1008\t\t// The path must exist on the node before configuration is applied.\n1009\t\t// When an artifact is requested, artifacts found at this location will be used instead of\n1010\t\t// retrieving from the registry.\n1011\t\t// The path is required and must be between 1 and 256 characters long, begin with a forward slash,\n1012\t\t// and only contain the characters a-z, A-Z, 0-9, '/', '.', '_', and '-'.\n1013\t\t// Consecutive forward slashes are not permitted.\n1014\t\t// +required\n1015\t\tPath StorePath `json:\"path,omitempty\"`\n1016\t}\n1017\t\n1018\t// ContainerRuntimeConfigStatus defines the observed state of a ContainerRuntimeConfig\n1019\ttype ContainerRuntimeConfigStatus struct {\n1020\t\t// observedGeneration represents the generation observed by the controller.\n1021\t\t// +optional\n1022\t\tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n1023\t\n1024\t\t// conditions represents the latest available observations of current state.\n1025\t\t// +listType=atomic\n1026\t\t// +optional\n1027\t\tConditions []ContainerRuntimeConfigCondition `json:\"conditions\"`\n1028\t}\n1029\t\n1030\t// ContainerRuntimeConfigCondition defines the state of the ContainerRuntimeConfig\n1031\ttype ContainerRuntimeConfigCondition struct {\n1032\t\t// type specifies the state of the operator's reconciliation functionality.\n1033\t\t// +optional\n1034\t\tType ContainerRuntimeConfigStatusConditionType `json:\"type\"`\n1035\t\n1036\t\t// status of the condition, one of True, False, Unknown.\n1037\t\t// +optional\n1038\t\tStatus corev1.ConditionStatus `json:\"status,omitempty\"`\n1039\t\n1040\t\t// lastTransitionTime is the time of the last update to the current status object.\n1041\t\t// +nullable\n1042\t\t// +optional\n1043\t\tLastTransitionTime metav1.Time `json:\"lastTransitionTime\"`\n1044\t\n1045\t\t// reason is the reason for the condition's last transition.  Reasons are PascalCase\n1046\t\t// +optional\n1047\t\tReason string `json:\"reason,omitempty\"`\n1048\t\n1049\t\t// message provides additional information about the current condition.\n1050\t\t// This is only to be consumed by humans.\n1051\t\t// +optional\n1052\t\tMessage string `json:\"message,omitempty\"`\n1053\t}\n1054\t\n1055\t// ContainerRuntimeConfigStatusConditionType is the state of the operator's reconciliation functionality.\n1056\ttype ContainerRuntimeConfigStatusConditionType string\n1057\t\n1058\tconst (\n1059\t\t// ContainerRuntimeConfigSuccess designates a successful application of a ContainerRuntimeConfig CR.\n1060\t\tContainerRuntimeConfigSuccess ContainerRuntimeConfigStatusConditionType = \"Success\"\n1061\t\n1062\t\t// ContainerRuntimeConfigFailure designates a failure applying a ContainerRuntimeConfig CR.\n1063\t\tContainerRuntimeConfigFailure ContainerRuntimeConfigStatusConditionType = \"Failure\"\n1064\t)\n1065\t\n1066\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n1067\t\n1068\t// ContainerRuntimeConfigList is a list of ContainerRuntimeConfig resources\n1069\t//\n1070\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n1071\t// +openshift:compatibility-gen:level=1\n1072\ttype ContainerRuntimeConfigList struct {\n1073\t\tmetav1.TypeMeta `json:\",inline\"`\n1074\t\tmetav1.ListMeta `json:\"metadata\"`\n1075\t\n1076\t\tItems []ContainerRuntimeConfig `json:\"items\"`\n1077\t}\n1078\t"}]},"parent_tool_use_id":"toolu_vrtx_01LvxZJ4Yutvn6tN8jjixSiJ","session_id":"b36bfe9c-b5ba-4115-8f21-75f99f58dba6","uuid":"762a0866-0bc6-4af2-bdbd-19473d9754aa","timestamp":"2026-06-22T21:38:56.275Z","subagent_type":"Explore","task_description":"Find MachineConfigPool and KubeletConfig examples and best practices"}
