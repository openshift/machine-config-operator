{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_019r2pHVUUy4J2Myu24PyWzN","type":"tool_result","content":"1\tpackage common\n2\t\n3\tconst (\n4\t\t// MCONamespace is the namespace that should be used for all API objects owned by the MCO by default\n5\t\tMCONamespace = \"openshift-machine-config-operator\"\n6\t\n7\t\t// OpenshiftConfigManagedNamespace is the namespace that has the etc-pki-entitlement/Simple Content Access Cert\n8\t\tOpenshiftConfigManagedNamespace = \"openshift-config-managed\"\n9\t\n10\t\t// SimpleContentAccessSecret is the secret that holds the SimpleContentAccess cert which provides RHEL entitlements\n11\t\tSimpleContentAccessSecretName = \"etc-pki-entitlement\"\n12\t\t// MachineAPINamespace is the namespace that should be used for all API objects owned by the machine api operator\n13\t\tMachineAPINamespace = \"openshift-machine-api\"\n14\t\n15\t\t// GlobalPullSecretName is the name of the global pull secret\n16\t\tGlobalPullSecretName = \"pull-secret\"\n17\t\n18\t\t// OpenshiftConfigNamespace is the namespace that has the global pull secret\n19\t\tOpenshiftConfigNamespace = \"openshift-config\"\n20\t\n21\t\t// GlobalPullCopySecret is a copy of the cluster wide pull secret. In OCL, this is used if the base image pull secret is not provided.\n22\t\tGlobalPullSecretCopyName = \"global-pull-secret-copy\"\n23\t\n24\t\t// GeneratedByControllerVersionAnnotationKey is used to tag the machineconfigs generated by the controller with the version of the controller.\n25\t\tGeneratedByControllerVersionAnnotationKey = \"machineconfiguration.openshift.io/generated-by-controller-version\"\n26\t\n27\t\t// ReleaseImageVersionAnnotationKey is used to tag the rendered machineconfigs & controller config with the release image version.\n28\t\tReleaseImageVersionAnnotationKey = \"machineconfiguration.openshift.io/release-image-version\"\n29\t\n30\t\t// OSImageURLOverriddenKey is used to tag a rendered machineconfig when OSImageURL has been overridden from default using machineconfig\n31\t\tOSImageURLOverriddenKey = \"machineconfiguration.openshift.io/os-image-url-overridden\"\n32\t\n33\t\t// RenderedMachineConfigPrefix is the name prefix for rendered MachineConfigs\n34\t\tRenderedMachineConfigPrefix = \"rendered-\"\n35\t\n36\t\t// ControllerConfigName is the name of the ControllerConfig object that controllers use\n37\t\tControllerConfigName = \"machine-config-controller\"\n38\t\n39\t\t// KernelTypeDefault denominates the default kernel type\n40\t\tKernelTypeDefault = \"default\"\n41\t\n42\t\t// KernelTypeRealtime denominates the realtime kernel type\n43\t\tKernelTypeRealtime = \"realtime\"\n44\t\n45\t\t// KernelType64kPages denominates the 64k pages kernel\n46\t\tKernelType64kPages = \"64k-pages\"\n47\t\n48\t\t// MasterLabel defines the label associated with master node. The master taint uses the same label as taint's key\n49\t\tMasterLabel = \"node-role.kubernetes.io/master\"\n50\t\n51\t\t// MCNameSuffixAnnotationKey is used to keep track of the machine config name associated with a CR\n52\t\tMCNameSuffixAnnotationKey = \"machineconfiguration.openshift.io/mc-name-suffix\"\n53\t\n54\t\t// MaxMCNameSuffix is the maximum value of the name suffix of the machine config associated with kubeletconfig and containerruntime objects\n55\t\tMaxMCNameSuffix int = 9\n56\t\n57\t\t// ClusterFeatureInstanceName is a singleton name for featureGate configuration\n58\t\tClusterFeatureInstanceName = \"cluster\"\n59\t\n60\t\t// ClusterNodeInstanceName is a singleton name for node configuration\n61\t\tClusterNodeInstanceName = \"cluster\"\n62\t\n63\t\t// APIServerInstanceName is a singleton name for APIServer configuration\n64\t\tAPIServerInstanceName = \"cluster\"\n65\t\n66\t\t// ClusterInstanceNameOSImageStream is the name of the singleton cluster-scoped OSImageStream instance.\n67\t\tClusterInstanceNameOSImageStream = \"cluster\"\n68\t\n69\t\t// InternalReleaseImageInstanceName is a singleton name for InternalReleaseImage\n70\t\tInternalReleaseImageInstanceName = \"cluster\"\n71\t\n72\t\t// InternalReleaseImageTLSSecretName is the name of the secret manifest containing the InternalReleaseImage TLS certificate.\n73\t\tInternalReleaseImageTLSSecretName = \"internal-release-image-tls\"\n74\t\n75\t\t// InternalReleaseImageAuthSecretName is the name of the secret containing IRI registry htpasswd auth credentials.\n76\t\tInternalReleaseImageAuthSecretName = \"internal-release-image-registry-auth\"\n77\t\n78\t\t// IRIRegistryPort is the port on which the IRI registry listens on master nodes.\n79\t\tIRIRegistryPort = 22625\n80\t\n81\t\t// IRIRegistryUsername is the fixed username used for IRI registry htpasswd authentication.\n82\t\tIRIRegistryUsername = \"openshift\"\n83\t\n84\t\t// APIServerInstanceName is a singleton name for APIServer configuration\n85\t\tAPIServerBootstrapFileLocation = \"/etc/mcs/bootstrap/api-server/api-server.yaml\"\n86\t\n87\t\t// MachineConfigPoolArbiter is the MachineConfigPool name given to the arbiter\n88\t\tMachineConfigPoolArbiter = \"arbiter\"\n89\t\n90\t\t// MachineConfigPoolMaster is the MachineConfigPool name given to the master\n91\t\tMachineConfigPoolMaster = \"master\"\n92\t\n93\t\t// MachineConfigPoolWorker is the MachineConfigPool name given to the worker\n94\t\tMachineConfigPoolWorker = \"worker\"\n95\t\n96\t\t// LayeringEnabledPoolLabel is the label that enables the \"layered\" workflow path for a pool.\n97\t\tLayeringEnabledPoolLabel = \"machineconfiguration.openshift.io/layering-enabled\"\n98\t\n99\t\tRebuildPoolLabel = \"machineconfiguration.openshift.io/rebuildImage\"\n100\t\n101\t\t// ExperimentalNewestLayeredImageEquivalentConfigAnnotationKey is the annotation that signifies which rendered config\n102\t\t// TODO(zzlotnik): Determine if we should use this still.\n103\t\tExperimentalNewestLayeredImageEquivalentConfigAnnotationKey = \"machineconfiguration.openshift.io/newestImageEquivalentConfig\"\n104\t\n105\t\t// InternalMCOIgnitionVersion is the ignition version that the MCO converts everything to internally. The intent here is that\n106\t\t// we should be able to update this constant when we bump the internal ignition version instead of having to hunt down all of\n107\t\t// the version references and figure out \"was this supposed to be explicitly 3.5.0 or just the default version which happens\n108\t\t// to be 3.5.0 currently\". Ideally if you find an explicit \"3.5.0\", it's supposed to be \"3.5.0\" version. If it's this constant,\n109\t\t// it's supposed to be the internal default version.\n110\t\tInternalMCOIgnitionVersion = \"3.5.0\"\n111\t\n112\t\t// This is the minimum acceptable ignition spec required for boot image updates. This should be updated to be in line with the above.\n113\t\tMinimumAcceptableStubIgnitionSpec = \"3\"\n114\t\n115\t\t// MachineConfigRoleLabel is the role on MachineConfigs, used to select for pools\n116\t\tMachineConfigRoleLabel = \"machineconfiguration.openshift.io/role\"\n117\t\n118\t\t// BootImagesConfigMapName is a Configmap of golden bootimages, updated by CVO on an upgrade\n119\t\tBootImagesConfigMapName = \"coreos-bootimages\"\n120\t\n121\t\t// MCOVersionHashKey is the key for indexing the MCO git version hash stored in the bootimages configmap\n122\t\tMCOVersionHashKey = \"MCOVersionHash\"\n123\t\n124\t\t// MCOReleaseImageVersionKey is the key for indexing the MCO release version stored in the bootimages configmap\n125\t\tMCOReleaseImageVersionKey = \"MCOReleaseImageVersion\"\n126\t\n127\t\t// MCOReleaseImageVersionKey is the key for indexing the OCP release version stored in the bootimages configmap\n128\t\tOCPReleaseVersionKey = \"releaseVersion\"\n129\t\n130\t\t// MCOOperatorKnobsObjectName is the name of the global MachineConfiguration \"knobs\" object that the MCO watches."}]},"parent_tool_use_id":"toolu_vrtx_01FVjokv2fbL5yUVz4FEGkAj","session_id":"b36bfe9c-b5ba-4115-8f21-75f99f58dba6","uuid":"78d57bb2-4290-4e85-bce5-a8bdfcc8aea1","timestamp":"2026-06-22T2