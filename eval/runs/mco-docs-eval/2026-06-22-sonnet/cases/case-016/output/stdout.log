{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01HLoxvcrrxDtMPUYjwXzgH4","type":"tool_result","content":"1465\t\t}\n1466\t\n1467\t\treturn preBuiltMCs\n1468\t}\n1469\t\n1470\t// IsCustomPool returns true if the pool is a custom pool (not master, worker, or arbiter)\n1471\tfunc IsCustomPool(pool *mcfgv1.MachineConfigPool) bool {\n1472\t\treturn pool.Name != MachineConfigPoolMaster &&\n1473\t\t\tpool.Name != MachineConfigPoolWorker &&\n1474\t\t\tpool.Name != MachineConfigPoolArbiter\n1475\t}\n1476\t\n1477\t// GetEffectiveOSImageStreamName returns the effective osImageStream name for a pool,\n1478\t// taking inheritance from the worker pool into account for custom pools.\n1479\t// Returns:\n1480\t// - The pool's explicit osImageStream.Name if set\n1481\t// - For custom pools: the worker pool's osImageStream.Name if the custom pool has none\n1482\t// - Empty string (which will resolve to the default stream)\n1483\t//\n1484\t// This function can return an error if the worker pool cannot be fetched.\n1485\tfunc GetEffectiveOSImageStreamName(pool *mcfgv1.MachineConfigPool, mcpLister mcfglistersv1.MachineConfigPoolLister) (string, error) {\n1486\t\t// If the pool explicitly sets an osImageStream, use it\n1487\t\tif pool.Spec.OSImageStream.Name != \"\" {\n1488\t\t\treturn pool.Spec.OSImageStream.Name, nil\n1489\t\t}\n1490\t\n1491\t\t// Only custom pools inherit from worker; standard pools use default directly\n1492\t\tif !IsCustomPool(pool) {\n1493\t\t\treturn \"\", nil\n1494\t\t}\n1495\t\n1496\t\t// For custom pools with no explicit stream, try to inherit from worker\n1497\t\tworkerPool, err := mcpLister.Get(MachineConfigPoolWorker)\n1498\t\tif err != nil {\n1499\t\t\t// If worker pool doesn't exist or can't be fetched, use default stream\n1500\t\t\tif !kerr.IsNotFound(err) {\n1501\t\t\t\treturn \"\", fmt.Errorf(\"failed to get worker pool for osImageStream inheritance: %w\", err)\n1502\t\t\t}\n1503\t\t\treturn \"\", nil\n1504\t\t}\n1505\t\n15