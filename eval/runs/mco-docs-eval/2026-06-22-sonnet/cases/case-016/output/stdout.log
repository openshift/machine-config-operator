rconv.FormatBool(*autoSystemReserved)\n49\t\t}\n50\t\n51\t\tif val, ok := userDefinedSystemReserved[\"memory\"]; ok && val != \"\" {\n52\t\t\tsystemReservedMemory = val\n53\t\t} else {\n54\t\t\tsystemReservedMemory = \"1Gi\"\n55\t\t}\n56\t\n57\t\tif val, ok := userDefinedSystemReserved[\"cpu\"]; ok && val != \"\" {\n58\t\t\tsystemReservedCPU = val\n59\t\t} else {\n60\t\t\tsystemReservedCPU = \"500m\"\n61\t\t}\n62\t\n63\t\tif val, ok := userDefinedSystemReserved[\"ephemeral-storage\"]; ok && val != \"\" {\n64\t\t\tsystemReservedEphemeralStorage = val\n65\t\t} else {\n66\t\t\tsystemReservedEphemeralStorage = \"1Gi\"\n67\t\t}\n68\t\n69\t\tconfig := fmt.Sprintf(\"NODE_SIZING_ENABLED=%s\\nSYSTEM_RESERVED_MEMORY=%s\\nSYSTEM_RESERVED_CPU=%s\\nSYSTEM_RESERVED_ES=%s\\n\",\n70\t\t\tautoNodeSizing, systemReservedMemory, systemReservedCPU, systemReservedEphemeralStorage)\n71\t\n72\t\tr := ctrlcommon.NewIgnFileBytesOverwriting(ctrlcommon.NodeSizingEnabledEnvPath, []byte(config))\n73\t\treturn &r\n74\t}\n75\t\n76\tfunc createNewKubeletLogLevelIgnition(level int32) *ign3types.File {\n77\t\tconfig := fmt.Sprintf(\"[Service]\\nEnvironment=\\\"KUBELET_LOG_LEVEL=%d\\\"\\n\", level)\n78\t\tr := ctrlcommon.NewIgnFileBytesOverwriting(\"/etc/systemd/system/kubelet.service.d/20-logging.conf\", []byte(config))\n79\t\treturn &r\n80\t}\n81\t\n82\tfunc createNewKubeletIgnition(yamlConfig []byte) *ign3types.File {\n83\t\n84\t\tr := ctrlcommon.NewIgnFileBytesOverwriting(\"/etc/kubernetes/kubelet.conf\", yamlConfig)\n85\t\treturn &r\n86\t}\n87\t\n88\tfunc createNewDefaultFeatureGate() *osev1.FeatureGate {\n89\t\treturn &osev1.FeatureGate{\n90\t\t\tObjectMeta: metav1.ObjectMeta{\n91\t\t\t\tName: ctrlcommon.ClusterFeatureInstanceName,\n92\t\t\t},\n93\t\t\tSpec: osev1.FeatureGateSpec{\n94\t\t\t\tFeatureGateSelection: osev1.FeatureGateSelection{\n95\t\t\t\t\tFeatureSet: osev1.Default,\n96\t\t\t\t},\n97\t\t\t},\n98\t\t}\n99\t}\n100\t"}]},"parent_tool_use_id":"toolu_vrtx_01FVjokv2fbL5yUVz4FEGkAj","sess