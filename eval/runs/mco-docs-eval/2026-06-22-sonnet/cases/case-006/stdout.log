{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01Ph7UMCAi8H5zYV7T8PPbWX","type":"tool_result","content":"1\tpackage main\n2\t\n3\timport (\n4\t\t\"context\"\n5\t\t\"fmt\"\n6\t\t\"time\"\n7\t\n8\t\tmcfgv1 \"github.com/openshift/api/machineconfiguration/v1\"\n9\t\tclientmachineconfigv1 \"github.com/openshift/client-go/machineconfiguration/clientset/versioned/typed/machineconfiguration/v1\"\n10\t\t\"github.com/openshift/machine-config-operator/devex/internal/pkg/utils\"\n11\t\tctrlcommon \"github.com/openshift/machine-config-operator/pkg/controller/common\"\n12\t\t\"github.com/openshift/machine-config-operator/test/framework\"\n13\t\tmetav1 \"k8s.io/apimachinery/pkg/apis/meta/v1\"\n14\t\t\"k8s.io/apimachinery/pkg/util/wait\"\n15\t\t\"k8s.io/klog/v2\"\n16\t)\n17\t\n18\ttype moscOpts struct {\n19\t\tpoolName              string\n20\t\tcontainerfileContents string\n21\t\tpullSecretName        string\n22\t\tpushSecretName        string\n23\t\tfinalPullSecretName   string\n24\t\tfinalImagePullspec    string\n25\t}\n26\t\n27\tfunc newMachineOSConfig(opts moscOpts) *mcfgv1.MachineOSConfig {\n28\t\treturn &mcfgv1.MachineOSConfig{\n29\t\t\tObjectMeta: metav1.ObjectMeta{\n30\t\t\t\tName: opts.poolName,\n31\t\t\t\tLabels: map[string]string{\n32\t\t\t\t\tcreatedByOnClusterBuildsHelper: \"\",\n33\t\t\t\t},\n34\t\t\t},\n35\t\t\tSpec: mcfgv1.MachineOSConfigSpec{\n36\t\t\t\tMachineConfigPool: mcfgv1.MachineConfigPoolReference{\n37\t\t\t\t\tName: opts.poolName,\n38\t\t\t\t},\n39\t\t\t\tBaseImagePullSecret: &mcfgv1.ImageSecretObjectReference{\n40\t\t\t\t\tName: opts.pullSecretName,\n41\t\t\t\t},\n42\t\t\t\tRenderedImagePushSecret: mcfgv1.ImageSecretObjectReference{\n43\t\t\t\t\tName: opts.pushSecretName,\n44\t\t\t\t},\n45\t\t\t\tRenderedImagePushSpec: mcfgv1.ImageTagFormat(opts.finalImagePullspec),\n46\t\t\t\tImageBuilder: mcfgv1.MachineOSImageBuilder{\n47\t\t\t\t\tImageBuilderType: mcfgv1.JobBuilder,\n48\t\t\t\t},\n49\t\t\t\tContainerfile: []mcfgv1.MachineOSContainerfile{\n50\t\t\t\t\t{\n51\t\t\t\t\t\tContainerfileArch: mcfgv1.NoArch,\n52\t\t\t\t\t\tContent:           opts.containerfileContents,\n53\t\t\t\t\t},\n54\t\t\t\t},\n55\t\t\t},\n56\t\t}\n57\t\n58\t}\n59\t\n60\tfunc getMachineOSConfigForPool(cs *framework.ClientSet, pool *mcfgv1.MachineConfigPool) (*mcfgv1.MachineOSConfig, error) {\n61\t\tclient := clientmachineconfigv1.NewForConfigOrDie(cs.GetRestConfig())\n62\t\n63\t\tmoscList, err := client.MachineOSConfigs().List(context.TODO(), metav1.ListOptions{})\n64\t\tif err != nil {\n65\t\t\treturn nil, err\n66\t\t}\n67\t\n68\t\tfound := filterMachineOSConfigsForPool(moscList, pool)\n69\t\tif len(found) == 1 {\n70\t\t\treturn found[0], nil\n71\t\t}\n72\t\n73\t\tif len(found) == 0 {\n74\t\t\treturn nil, fmt.Errorf(\"no MachineOSConfigs exist for MachineConfigPool %s\", pool.Name)\n75\t\t}\n76\t\n77\t\tnames := []string{}\n78\t\tfor _, mosc := range found {\n79\t\t\tnames = append(names, mosc.Name)\n80\t\t}\n81\t\n82\t\treturn nil, fmt.Errorf(\"expected one MachineOSConfig for MachineConfigPool %s, found multiple: %v\", pool.Name, names)\n83\t}\n84\t\n85\tfunc filterMachineOSConfigsForPool(moscList *mcfgv1.MachineOSConfigList, pool *mcfgv1.MachineConfigPool) []*mcfgv1.MachineOSConfig {\n86\t\tfound := []*mcfgv1.MachineOSConfig{}\n87\t\n88\t\tfor _, mosc := range moscList.Items {\n89\t\t\tif mosc.Spec.MachineConfigPool.Name == pool.Name {\n90\t\t\t\tmosc := mosc\n91\t\t\t\tfound = append(found, &mosc)\n92\t\t\t}\n93\t\t}\n94\t\n95\t\treturn found\n96\t}\n97\t\n98\tfunc createMachineOSConfig(cs *framework.ClientSet, mosc *mcfgv1.MachineOSConfig) error {\n99\t\tclient := clientmachineconfigv1.NewForConfigOrDie(cs.GetRestConfig())\n100\t\n101\t\t_, err := client.MachineOSConfigs().Create(context.TODO(), mosc, metav1.CreateOptions{})\n102\t\tif err != nil {\n103\t\t\treturn fmt.Errorf(\"could not create MachineOSConfig %s: %w\", mosc.Name, err)\n104\t\t}\n105\t\n106\t\tklog.Infof(\"Created MachineOSConfig %s\", mosc.Name)\n107\t\treturn nil\n108\t}\n109\t\n110\tfunc deleteMachineOSConfigs(cs *framework.ClientSet) error {\n111\t\tclient := clientmachineconfigv1.NewForConfigOrDie(cs.GetRestConfig())\n112\t\n113\t\tmoscList, err := client.MachineOSConfigs().List(context.TODO(), metav1.ListOptions{})\n114\t\tif err != nil {\n115\t\t\treturn err\n116\t\t}\n117\t\n118\t\tfor _, mosc := range moscList.Items {\n119\t\t\terr := client.MachineOSConfigs().Delete(context.TODO(), mosc.Name, metav1.DeleteOptions{})\n120\t\t\tif err != nil {\n121\t\t\t\treturn fmt.Errorf(\"could not delete MachineOSConfig %s: %w\", mosc.Name, err)\n122\t\t\t}\n123\t\n124\t\t\tklog.Infof(\"Deleted MachineOSConfig %s\", mosc.Name)\n125\t\t}\n126\t\n127\t\treturn err\n128\t}\n129\t\n130\tfunc deleteMachineOSBuilds(cs *framework.ClientSet) error {\n131\t\tclient := clientmachineconfigv1.NewForConfigOrDie(cs.GetRestConfig())\n132\t\n133\t\tmosbList, err := client.MachineOSBuilds().List(context.TODO(), metav1.ListOptions{})\n134\t\tif err != nil {\n135\t\t\treturn err\n136\t\t}\n137\t\n138\t\tfor _, mosb := range mosbList.Items {\n139\t\t\terr := client.MachineOSBuilds().Delete(context.TODO(), mosb.Name, metav1.DeleteOptions{})\n140\t\t\tif err != nil {\n141\t\t\t\treturn fmt.Errorf(\"could not delete MachineOSBuild %s: %w\", mosb.Name, err)\n142\t\t\t}\n143\t\n144\t\t\tklog.Infof(\"Deleted MachineOSBuild %s\", mosb.Name)\n145\t\t}\n146\t\n147\t\treturn err\n148\t}\n149\t\n150\tfunc waitForBuildToComplete(ctx context.Context, cs *framework.ClientSet, poolName string) error {\n151\t\tisExists := false\n152\t\tisPending := false\n153\t\tisBuilding := false\n154\t\tisSuccess := false\n155\t\n156\t\tstart := time.Now()\n157\t\n158\t\treturn waitForMachineOSBuildToReachState(ctx, cs, poolName, func(mosb *mcfgv1.MachineOSBuild, err error) (bool, error) {\n159\t\t\t// There is a lag between when the MachineOSConfig is created and the\n160\t\t\t// MachineOSBuild object gets created and is available.\n161\t\t\tif err != nil && !utils.IsNotFoundErr(err) {\n162\t\t\t\treturn false, err\n163\t\t\t}\n164\t\n165\t\t\t// If the MachineOSBuild has not been created yet, try again later.\n166\t\t\tif utils.IsNotFoundErr(err) {\n167\t\t\t\treturn false, nil\n168\t\t\t}\n169\t\n170\t\t\t// If the MachineOSBuild exists, we can interrogate its state.\n171\t\t\tif !isExists && mosb != nil && err == nil {\n172\t\t\t\tisExists = true\n173\t\t\t\tklog.Infof(\"Build %s exists after %s\", mosb.Name, time.Since(start))\n174\t\t\t}\n175\t\n176\t\t\tstate := ctrlcommon.NewMachineOSBuildState(mosb)\n177\t\n178\t\t\tif !isPending && state.IsBuildPending() {\n179\t\t\t\tisPending = true\n180\t\t\t\tklog.Infof(\"Build %s is now pending after %s\", mosb.Name, time.Since(start))\n181\t\t\t}\n182\t\n183\t\t\tif !isBuilding && state.IsBuilding() {\n184\t\t\t\tisBuilding = true\n185\t\t\t\tklog.Infof(\"Build %s is now running after %s\", mosb.Name, time.Since(start))\n186\t\t\t}\n187\t\n188\t\t\tif !isSuccess && state.IsBuildSuccess() {\n189\t\t\t\tisSuccess = true\n190\t\t\t\tklog.Infof(\"Build %s is complete after %s\", mosb.Name, time.Since(start))\n191\t\t\t\treturn true, nil\n192\t\t\t}\n193\t\n194\t\t\tif state.IsBuildFailure() {\n195\t\t\t\treturn false, fmt.Errorf(\"build %s failed after %s\", mosb.Name, time.Since(start))\n196\t\t\t}\n197\t\n198\t\t\treturn false, nil\n199\t\t})\n200\t}\n201\t\n202\tfunc waitForMachineOSBuildToReachState(ctx context.Context, cs *framework.ClientSet, poolName string, condFunc func(*mcfgv1.MachineOSBuild, error) (bool, error)) error {\n203\t\treturn wait.PollUntilContextCancel(ctx, time.Second, true, func(funcCtx context.Context) (bool, error) {\n204\t\t\tmosb, err := utils.GetMachineOSBuildForPoolName(funcCtx, cs, poolName)\n205\t\t\treturn condFunc(mosb, err)\n206\t\t})\n207\t}\n208\t"}]},"parent_tool_use_id":"toolu_vrtx_014NA5Hm4ucczaQabTwCT8iW","session_id":"e75a21bc-7faa-413c-8450-02eaf032edac","uuid":"2c7d13f5-5eab-4173-97e6-19914d9408a4","timestamp":"2026-06-22T21:07:38.753Z","subagent_type":"Explore","task_description":"Search for MachineOSConfig and on-cluster layering docs"}
