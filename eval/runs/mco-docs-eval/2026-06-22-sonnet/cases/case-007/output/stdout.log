Funcs.Add(helpers.CreatePoolAndApplyMC(t, cs, mcpName, mc))\n99\t\t\t},\n100\t\t\tTeardownFunc: func() {\n101\t\t\t\tcleanupFuncs.Run()\n102\t\t\t},\n103\t\t}\n104\t\n105\t\tsharedOpts := e2eShared.SharedTestOpts{\n106\t\t\tConfigDriftTestOpts: configOpts,\n107\t\t}\n108\t\n109\t\te2eShared.Run(t, sharedOpts)\n110\t}\n111\t\n112\tfunc TestKernelArguments(t *testing.T) {\n113\t\tcs := framework.NewClientSet(\"\")\n114\t\n115\t\tdelete := helpers.CreateMCP(t, cs, \"infra\")\n116\t\tworkerOldMc := helpers.GetMcName(t, cs, \"worker\")\n117\t\n118\t\tunlabelFunc := helpers.LabelRandomNodeFromPool(t, cs, \"worker\", \"node-role.kubernetes.io/infra\")\n119\t\toldInfraConfig := helpers.CreateMC(\"old-infra\", \"infra\")\n120\t\n121\t\tt.Cleanup(func() {\n122\t\t\tunlabelFunc()\n123\t\t\t// wait for the mcp to go back to previous config\n124\t\t\tif err := helpers.WaitForPoolComplete(t, cs, \"worker\", workerOldMc); err != nil {\n125\t\t\t\tt.Fatal(err)\n126\t\t\t}\n127\t\t\tdelete()\n128\t\t\trequire.Nil(t, cs.MachineConfigs().Delete(context.TODO(), oldInfraConfig.Name, metav1.DeleteOptions{}))\n129\t\t})\n130\t\t// create old mc to have something to verify we successfully rolled back\n131\t\t_, err := cs.MachineConfigs().Create(context.TODO(), oldInfraConfig, metav1.CreateOptions{})\n132\t\trequire.Nil(t, err)\n133\t\toldInfraRenderedConfig, err := helpers.WaitForRenderedConfig(t, cs, \"infra\", oldInfraConfig.Name)\n134\t\terr = helpers.WaitForPoolComplete(t, cs, \"infra\", oldInfraRenderedConfig)\n135\t\trequire.Nil(t, err)\n136\t\n137\t\t// create kargs MC\n138\t\tkargsMC := &mcfgv1.MachineConfig{\n139\t\t\tObjectMeta: metav1.ObjectMeta{\n140\t\t\t\tName:   fmt.Sprintf(\"kargs-%s\", uuid.NewUUID()),\n141\t\t\t\tLabels: helpers.MCLabelForRole(\"infra\"),\n142\t\t\t},\n143\t\t\tSpec: mcfgv1.MachineConfigSpec{\n144\t\t\t\tConfig: runtime.RawExtension{\n145\t\t\t\t\tRaw: helpers.MarshalOrDie(ctrlcommon.NewIgnConfig()),\n146\t\t\t\t},\n147\t\t\t\tKernelArguments: []string{\"nosmt\", \"foo=bar\", \"foo=baz\", \" baz=test bar=hello world\"},\n148\t\t\t},\n149\t\t}\n150\t\n151\t\t_, err = cs.MachineConfigs().Create(context.TODO(), kargsMC, metav1.CreateOptions{})\n152\t\trequire.Nil(t, err)\n153\t\tt.Logf(\"Created %s\", kargsMC.Name)\n154\t\trenderedConfig, err := helpers.WaitForRenderedConfig(t, cs, \"infra\", kargsMC.Name)\n155\t\trequire.Nil(t, err)\n156\t\terr = helpers.WaitForPoolComplete(t, cs, \"infra\", renderedConfig)\n157\t\trequire.Nil(t, err)\n158\t\n159\t\t// Re-fetch the infra node for updated annotations\n160\t\tinfraNode := helpers.GetSingleNodeByRole(t, cs, \"infra\")\n161\t\tassert.Equal(t, infraNode.Annotations[constants.CurrentMachineConfigAnnotationKey], renderedConfig)\n162\t\tassert.Equal(t, infraNode.Annotations[constants.MachineConfigDaemonStateAnnotationKey], constants.MachineConfigDaemonStateDone)\n163\t\tkargs := helpers.ExecCmdOnNode(t, cs, infraNode, \"cat\", \"/rootfs/proc/cmdline\")\n164\t\texpectedKernelArgs := []string{\"nosmt\", \"foo=bar\", \"foo=baz\", \"baz=test\", \"bar=hello world\"}\n165\t\tfor _, v := range expectedKernelArgs {\n166\t\t\tif !strings.Contains(kargs, v) {\n167\t\t\t\tt.Fatalf(\"Missing %q in kargs: %q\", v, kargs)\n168\t\t\t}\n169\t\t}"}]},"parent_tool_use_id":"toolu_vrtx_01DshDtT9WDTGPZuuhDNzvTz","session_id":"b3810a3c-eea7-4cd5-9b89-22b4f26138cd","uuid":"4239fa5e-1a1a-41f7-99b8-2f88276a9886","timestamp":"2026-06-22T21:10:53.436Z","subagent_type":"Explore","task_description":"Find MachineConfig YAML examples with files and kernelArguments"}
