{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_013XjRtyu31HC5w4JLN89gwo","type":"tool_result","content":"100\t\n101\t\t// ExperimentalNewestLayeredImageEquivalentConfigAnnotationKey is the annotation that signifies which rendered config\n102\t\t// TODO(zzlotnik): Determine if we should use this still.\n103\t\tExperimentalNewestLayeredImageEquivalentConfigAnnotationKey = \"machineconfiguration.openshift.io/newestImageEquivalentConfig\"\n104\t\n105\t\t// InternalMCOIgnitionVersion is the ignition version that the MCO converts everything to internally. The intent here is that\n106\t\t// we should be able to update this constant when we bump the internal ignition version instead of having to hunt down all of\n107\t\t// the version references and figure out \"was this supposed to be explicitly 3.5.0 or just the default version which happens\n108\t\t// to be 3.5.0 currently\". Ideally if you find an explicit \"3.5.0\", it's supposed to be \"3.5.0\" version. If it's this constant,\n109\t\t// it's supposed to be the internal default version.\n110\t\tInternalMCOIgnitionVersion = \"3.5.0\"\n111\t\n112\t\t// This is the minimum acceptable ignition spec required for boot image updates. This should be updated to be in line with the above.\n113\t\tMinimumAcceptableStubIgnitionSpec = \"3\"\n114\t\n115\t\t// MachineConfigRoleLabel is the role on MachineConfigs, used to select for pools\n116\t\tMachineConfigRoleLabel = \"machineconfiguration.openshift.io/role\"\n117\t\n118\t\t// BootImagesConfigMapName is a Configmap of golden bootimages, updated by CVO on an upgrade\n119\t\tBootImagesConfigMapName = \"coreos-bootimages\"\n120\t\n121\t\t// MCOVersionHashKey is the key for indexing the MCO git version hash stored in the bootimages configmap\n122\t\tMCOVersionHashKey = \"MCOVersionHash\"\n123\t\n124\t\t// MCOReleaseImageVersionKey is the key for indexing the MCO release version stored in the bootimages configmap\n125\t\tMCOReleaseImageVersionKey = \"MCOReleaseImageVersion\"\n126\t\n127\t\t// MCOReleaseImageVersionKey is the key for indexing the OCP release version stored in the bootimages configmap\n128\t\tOCPReleaseVersionKey = \"releaseVersion\"\n129\t\n130\t\t// MCOOperatorKnobsObjectName is the name of the global MachineConfiguration \"knobs\" object that the MCO watches.\n131\t\tMCOOperatorKnobsObjectName = \"cluster\"\n132\t\n133\t\t// BootImageOptedInAnnotation is used for book keeping when the MCO applies a default boot image configuration\n134\t\tBootImageOptedInAnnotation = \"machineconfiguration.openshift.io/boot-image-updates-opted-in-at\"\n135\t\n136\t\tServiceCARotateAnnotation = \"machineconfiguration.openshift.io/service-ca-rotate\"\n137\t\n138\t\tServiceCARotateTrue  = \"true\"\n139\t\tServiceCARotateFalse = \"false\"\n140\t\n141\t\t// This is where the installer generated MCS CA bundle was formally stored. This configmap is in the \"kube-system\" namespace.\n142\t\tRootCAConfigMapName = \"root-ca\"\n143\t\n144\t\t// This is the name of the configmap bundle and secret where the rotated MCS CA will be stored, in the MCO namespace.\n145\t\tMachineConfigServerCAName = \"machine-config-server-ca\"\n146\t\n147\t\t// This is the name of the secret which holds the MCS TLS cert. This is generated from the CAs listed above.\n148\t\tMachineConfigServerTLSSecretName = \"machine-config-server-tls\"\n149\t\n150\t\t// This is the label applied to *-user-data-managed secrets\n151\t\tMachineConfigServerCAManagedByConfigMapKey = \"machineconfiguration.openshift.io/managed-ca-bundle-derived-from-configmap\"\n152\t\n153\t\t// This is used to key in to the user-data secret\n154\t\tUserDataKey = \"userData\"\n155\t\n156\t\t// ign* are for the user-data ignition fields\n157\t\tIgnFieldIgnition = \"ignition\"\n158\t\tIgnFieldSource   = \"source\"\n159\t\tIgnFieldVersion  = \"version\"\n160\t\n161\t\t// Stub Ignition upgrade related annotation keys\n162\t\tStubIgnitionVersionAnnotation   = \"machineconfiguration.openshift.io/stub-ignition-upgraded-to\"\n163\t\tStubIgnitionTimestampAnnotation = \"machineconfiguration.openshift.io/stub-ignition-upgraded-at\"\n164\t\n165\t\t// NodeSizingEnabledEnvPath is the file path for the node sizing enabled environment file\n166\t\tNodeSizingEnabledEnvPath = \"/etc/node-sizing-enabled.env\"\n167\t\n168\t\t// Current Boot Image Skew Limits\n169\t\t// Note: Update units in status_test.go when the following are bumped"}]},"parent_tool_use_id":"toolu_vrtx_019jGp5d9AimjA864obPySnq","session_id":"97d67c05-bfc1-43f5-94c6-f2fb356410bf","uuid":"b01edd24-1ebc-4895-9f17-59478e4d9a28","timestamp":"2026-06-22T21:27:35.415Z","subagent_type":"Explore","task_description":"Find MachineConfig CRD schema for passwd and storage fields"}
