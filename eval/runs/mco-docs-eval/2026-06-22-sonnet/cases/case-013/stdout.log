{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01Lx3RmVBieiPirQvb3L9Cbw","type":"tool_result","content":"1\tpackage extended\n2\t\n3\timport (\n4\t\t\"crypto/rand\"\n5\t\t\"crypto/rsa\"\n6\t\t\"crypto/x509\"\n7\t\t\"encoding/pem\"\n8\t\t\"fmt\"\n9\t\t\"os/exec\"\n10\t\t\"path/filepath\"\n11\t\t\"regexp\"\n12\t\t\"strings\"\n13\t\n14\t\texpect \"github.com/google/goexpect\"\n15\t\tg \"github.com/onsi/ginkgo/v2\"\n16\t\to \"github.com/onsi/gomega\"\n17\t\texutil \"github.com/openshift/machine-config-operator/test/extended-priv/util\"\n18\t\tlogger \"github.com/openshift/machine-config-operator/test/extended-priv/util/logext\"\n19\t\t\"golang.org/x/crypto/ssh\"\n20\t\te2e \"k8s.io/kubernetes/test/e2e/framework\"\n21\t)\n22\t\n23\tvar _ = g.Describe(\"[sig-mco][Suite:openshift/machine-config-operator/disruptive][Serial][Disruptive] MCO password\", func() {\n24\t\tdefer g.GinkgoRecover()\n25\t\n26\t\tvar (\n27\t\t\toc   = exutil.NewCLI(\"mco-password\", exutil.KubeConfigPath())\n28\t\t\tuser string\n29\t\t\twMcp *MachineConfigPool\n30\t\t\tmMcp *MachineConfigPool\n31\t\t\t// Compact compatible MCP. If the node is compact/SNO this variable will be the master pool, else it will be the worker pool\n32\t\t\tmcp *MachineConfigPool\n33\t\t)\n34\t\n35\t\tg.JustBeforeEach(func() {\n36\t\t\tuser = \"core\"\n37\t\t\twMcp = NewMachineConfigPool(oc.AsAdmin(), MachineConfigPoolWorker)\n38\t\t\tmMcp = NewMachineConfigPool(oc.AsAdmin(), MachineConfigPoolMaster)\n39\t\t\tmcp = GetCompactCompatiblePool(oc.AsAdmin())\n40\t\n41\t\t\tPreChecks(oc)\n42\t\t})\n43\t\n44\t\tg.It(\"[PolarionID:59417][OTP] MCD create/update password with MachineConfig in CoreOS nodes\", func() {\n45\t\t\tvar (\n46\t\t\t\tmcName   = \"tc-59417-test-core-passwd\"\n47\t\t\t\tmcc      = NewController(oc.AsAdmin()).IgnoreLogsBeforeNowOrFail()\n48\t\t\t\tsilentOC = oc.AsAdmin()\n49\t\n50\t\t\t\tpassword          = exutil.GetRandomString()\n51\t\t\t\tpasswordHash      = OrFail[string](getHashPasswd(password))\n52\t\t\t\tupdatedPassword   = password + \"-2\"\n53\t\t\t\tupdatedPasswdHash = OrFail[string](getHashPasswd(updatedPassword))\n54\t\n55\t\t\t\texpectedReboot = false\n56\t\t\t)\n57\t\t\tsilentOC.NotShowInfo()\n58\t\n59\t\t\tallCoreos := mcp.GetCoreOsNodesOrFail()\n60\t\t\tif len(allCoreos) == 0 {\n61\t\t\t\tlogger.Infof(\"No CoreOs nodes are configured in the pool %s. We use master pool for testing\", mcp.GetName())\n62\t\t\t\tmcp = mMcp\n63\t\t\t\tallCoreos = mcp.GetCoreOsNodesOrFail()\n64\t\t\t}\n65\t\n66\t\t\tnode := allCoreos[0]\n67\t\t\tstartTime := node.GetDateOrFail()\n68\t\n69\t\t\texutil.By(\"Configure a password for 'core' user\")\n70\t\t\t_, _ = node.GetDate() // for debugging purposes, it prints the node's current time in the logs\n71\t\t\to.Expect(node.IgnoreEventsBeforeNow()).NotTo(o.HaveOccurred(),\n72\t\t\t\t\"Error getting the latest event in node %s\", node.GetName())\n73\t\n74\t\t\tmc := NewMachineConfig(silentOC, mcName, mcp.GetName())\n75\t\t\tmc.parameters = []string{fmt.Sprintf(`PWDUSERS=[{\"name\":\"%s\", \"passwordHash\": \"%s\" }]`, user, passwordHash)}\n76\t\t\tmc.skipWaitForMcp = true\n77\t\n78\t\t\tdefer mc.DeleteWithWait()\n79\t\t\tmc.create()\n80\t\n81\t\t\tmcp.waitForComplete()\n82\t\t\tlogger.Infof(\"OK!\\n\")\n83\t\n84\t\t\texutil.By(\"Check MCD logs to make sure drain and reboot are skipped\")\n85\t\t\tcheckDrainAction(expectedReboot, node, mcc)\n86\t\t\tcheckRebootAction(expectedReboot, node, startTime)\n87\t\t\tlogger.Infof(\"OK!\\n\")\n88\t\n89\t\t\texutil.By(\"Check events to make sure that drain and reboot events were not triggered\")\n90\t\t\tnodeEvents, eErr := node.GetEvents()\n91\t\t\to.Expect(eErr).ShouldNot(o.HaveOccurred(), \"Error getting drain events for node %s\", node.GetName())\n92\t\t\to.Expect(nodeEvents).NotTo(HaveEventsSequence(\"Drain\"), \"Error, a Drain event was triggered but it shouldn't\")\n93\t\t\to.Expect(nodeEvents).NotTo(HaveEventsSequence(\"Reboot\"), \"Error, a Reboot event was triggered but it shouldn't\")\n94\t\t\tlogger.Infof(\"OK!\\n\")\n95\t\n96\t\t\texutil.By(\"Verify that user 'core' can login with the configured password\")\n97\t\t\tlogger.Infof(\"verifying node %s\", node.GetName())\n98\t\t\tbresp, err := node.ExecuteDebugExpectBatch(DefaultExpectTimeout, getPasswdValidator(user, password))\n99\t\t\to.Expect(err).NotTo(o.HaveOccurred(), \"Error in the login process in node %s:\\n %s\", node.GetName(), bresp)\n100\t\t\tlogger.Infof(\"OK!\\n\")\n101\t\n102\t\t\texutil.By(\"Update the password value\")\n103\t\t\tpatchErr := mc.Patch(\"json\",\n104\t\t\t\tfmt.Sprintf(`[{ \"op\": \"add\", \"path\": \"/spec/config/passwd/users/0/passwordHash\", \"value\": \"%s\"}]`, updatedPasswdHash))\n105\t\n106\t\t\to.Expect(patchErr).NotTo(o.HaveOccurred(),\n107\t\t\t\t\"Error patching mc %s to update the 'core' user password\")\n108\t\n109\t\t\tmcp.waitForComplete()\n110\t\n111\t\t\tlogger.Infof(\"OK!\\n\")\n112\t\n113\t\t\texutil.By(\"Verify that user 'core' can login with the new password\")\n114\t\t\tlogger.Infof(\"verifying node %s\", node.GetName())\n115\t\t\tbresp, err = node.ExecuteDebugExpectBatch(DefaultExpectTimeout, getPasswdValidator(user, updatedPassword))\n116\t\t\to.Expect(err).NotTo(o.HaveOccurred(), \"Error in the login process in node %s:\\n %s\", node.GetName(), bresp)\n117\t\t\tlogger.Infof(\"OK!\\n\")\n118\t\n119\t\t\texutil.By(\"Remove the password\")\n120\t\t\tmc.Delete()\n121\t\t\tmcp.waitForComplete()\n122\t\t\tlogger.Infof(\"OK!\\n\")\n123\t\n124\t\t\texutil.By(\"Verify that user 'core' can not login using a password anymore\")\n125\t\t\tlogger.Infof(\"verifying node %s\", node.GetName())\n126\t\t\tbresp, err = node.ExecuteDebugExpectBatch(DefaultExpectTimeout, getPasswdValidator(user, updatedPassword))\n127\t\t\to.Expect(err).To(o.HaveOccurred(), \"User 'core' was able to login using a password in node %s, but it should not be possible:\\n %s\", node.GetName(), bresp)\n128\t\t\tlogger.Infof(\"OK!\\n\")\n129\t\n130\t\t})\n131\t\n132\t\tg.It(\"[PolarionID:72137][OTP] Create a password for a user different from 'core' user\", func() {\n133\t\t\tvar (\n134\t\t\t\tmcName       = \"mco-tc-59900-wrong-user-password\"\n135\t\t\t\twrongUser    = \"root\"\n136\t\t\t\tpasswordHash = fmt.Sprintf(\"fake-hash-%s\", exutil.GetRandomString())\n137\t\n138\t\t\t\texpectedRDReason  = \"\"\n139\t\t\t\texpectedRDMessage = regexp.QuoteMeta(`ignition passwd user section contains unsupported changes: non-core user`)\n140\t\t\t)\n141\t\n142\t\t\texutil.By(\"Create a password for a non-core user using a MC\")\n143\t\n144\t\t\tmc := NewMachineConfig(oc.AsAdmin(), mcName, mcp.GetName())\n145\t\t\tmc.parameters = []string{fmt.Sprintf(`PWDUSERS=[{\"name\":\"%s\", \"passwordHash\": \"%s\" }]`, wrongUser, passwordHash)}\n146\t\t\tmc.skipWaitForMcp = true\n147\t\n148\t\t\tvalidateMcpRenderDegraded(mc, mcp, expectedRDMessage, expectedRDReason)\n149\t\t})\n150\t\n151\t\t// https://issues.redhat.com/browse/MCO-1696\n152\t\tg.It(\"[PolarionID:59424][OTP] ssh keys can be found in new dir on RHCOS9 node\", func() {\n153\t\t\tvar (\n154\t\t\t\tallCoreOsNodes = wMcp.GetCoreOsNodesOrFail()\n155\t\t\t\tallMasters     = mMcp.GetNodesOrFail()\n156\t\t\t)\n157\t\n158\t\t\texutil.By(\"Get currently configured authorizedkeys in the cluster\")\n159\t\t\twMc, err := wMcp.GetConfiguredMachineConfig()\n160\t\t\to.Expect(err).NotTo(o.HaveOccurred(), \"Error getting the current configuration for worker pool\")"}]},"parent_tool_use_id":"toolu_vrtx_019jGp5d9AimjA864obPySnq","session_id":"97d67c05-bfc1-43f5-94c6-f2fb356410bf","uuid":"ce405529-ad3b-4328-86e5-00a025feba25","timestamp":"2026-06-22T21:27:59.168Z","subagent_type":"Explore","task_description":"Find MachineConfig CRD schema for passwd and storage fields"}
