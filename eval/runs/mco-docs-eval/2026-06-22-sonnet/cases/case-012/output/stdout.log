70\t\t\t},\n171\t\t\tUnits: []opv1.NodeDisruptionPolicyStatusUnit{\n172\t\t\t\t{\n173\t\t\t\t\tName: constants.IRIRegistryServiceName,\n174\t\t\t\t\tActions: []opv1.NodeDisruptionPolicyStatusAction{\n175\t\t\t\t\t\t{\n176\t\t\t\t\t\t\tType: opv1.DaemonReloadStatusAction,\n177\t\t\t\t\t\t},\n178\t\t\t\t\t\t{\n179\t\t\t\t\t\t\tType: opv1.RestartStatusAction,\n180\t\t\t\t\t\t\tRestart: &opv1.RestartService{\n181\t\t\t\t\t\t\t\tServiceName: constants.IRIRegistryServiceName,\n182\t\t\t\t\t\t\t},\n183\t\t\t\t\t\t},\n184\t\t\t\t\t},\n185\t\t\t\t},\n186\t\t\t},\n187\t\t\tSSHKey: opv1.NodeDisruptionPolicyStatusSSHKey{\n188\t\t\t\tActions: []opv1.NodeDisruptionPolicyStatusAction{\n189\t\t\t\t\t{\n190\t\t\t\t\t\tType: opv1.NoneStatusAction,\n191\t\t\t\t\t},\n192\t\t\t\t},\n193\t\t\t},\n194\t\t}\n195\t)\n196\t\n197\t// NewMachineConfigPoolCondition creates a new MachineConfigPool condition.\n198\tfunc NewMachineConfigPoolCondition(condType mcfgv1.MachineConfigPoolConditionType, status corev1.ConditionStatus, reason, message string) *mcfgv1.MachineConfigPoolCondition {\n199\t\treturn &mcfgv1.MachineConfigPoolCondition{\n200\t\t\tType:               condType,"}]},"parent_tool_use_id":"toolu_vrtx_012eYNRCZfJyWnRLE9EjXoPk","session_id":"1ca7e20c-f463-4aff-8411-4663c8d63aa4","uuid":"ba38f2bb-c832-4c5c-ac75-19a7865c1a4d","timestamp":"2026-06-22T21:24:00.066Z","subagent_type":"Explore","task_description":"Find NodeDisruptionPolicy API types and examples"}
