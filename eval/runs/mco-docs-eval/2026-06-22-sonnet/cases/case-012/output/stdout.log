1\t\t\t\t\t\t\t\tServiceName: \"crio.service\",\n52\t\t\t\t\t\t\t},\n53\t\t\t\t\t\t},\n54\t\t\t\t\t},\n55\t\t\t\t},\n56\t\t\t\t{\n57\t\t\t\t\tPath: constants.ContainerRegistryConfPath,\n58\t\t\t\t\tActions: []opv1.NodeDisruptionPolicyStatusAction{\n59\t\t\t\t\t\t{\n60\t\t\t\t\t\t\tType: opv1.SpecialStatusAction,\n61\t\t\t\t\t\t},\n62\t\t\t\t\t},\n63\t\t\t\t},\n64\t\t\t\t{\n65\t\t\t\t\tPath: constants.SigstoreRegistriesConfigDir,\n66\t\t\t\t\tActions: []opv1.NodeDisruptionPolicyStatusAction{\n67\t\t\t\t\t\t{\n68\t\t\t\t\t\t\tType: opv1.ReloadStatusAction,\n69\t\t\t\t\t\t\tReload: &opv1.ReloadService{\n70\t\t\t\t\t\t\t\tServiceName: \"crio.service\",\n71\t\t\t\t\t\t\t},\n72\t\t\t\t\t\t},\n73\t\t\t\t\t},\n74\t\t\t\t},\n75\t\t\t\t{\n76\t\t\t\t\tPath: constants.CrioPoliciesDir,\n77\t\t\t\t\tActions: []opv1.NodeDisruptionPolicyStatusAction{\n78\t\t\t\t\t\t{\n79\t\t\t\t\t\t\tType: opv1.ReloadStatusAction,\n80\t\t\t\t\t\t\tReload: &opv1.ReloadService{\n81\t\t\t\t\t\t\t\tServiceName: \"crio.service\",\n82\t\t\t\t\t\t\t},\n83\t\t\t\t\t\t},\n84\t\t\t\t\t},\n85\t\t\t\t},\n86\t\t\t\t{\n87\t\t\t\t\tPath: constants.OpenShiftNMStateConfigDir,\n88\t\t\t\t\tActions: []opv1.NodeDisruptionPolicyStatusAction{\n89\t\t\t\t\t\t{\n90\t\t\t\t\t\t\tType: opv1.NoneStatusAction,\n91\t\t\t\t\t\t},\n92\t\t\t\t\t},\n93\t\t\t\t},\n94\t\t\t\t{\n95\t\t\t\t\tPath: constants.UserCABundlePath,\n96\t\t\t\t\tActions: []opv1.NodeDisruptionPolicyStatusAction{\n97\t\t\t\t\t\t{\n98\t\t\t\t\t\t\tType: opv1.RestartStatusAction,\n99\t\t\t\t\t\t\tRestart: &opv1.RestartService{\n100\t\t\t\t\t\t\t\tServiceName: constants.UpdateCATrustServiceName,\n101\t\t\t\t\t\t\t},\n102\t\t\t\t\t\t},\n103\t\t\t\t\t\t{\n104\t\t\t\t\t\t\tType: opv1.RestartStatusAction,\n105\t\t\t\t\t\t\tRestart: &opv1.RestartService{\n106\t\t\t\t\t\t\t\tServiceName: \"crio.service\",\n107\t\t\t\t\t\t\t},\n108\t\t\t\t\t\t},\n109\t\t\t\t\t},\n110\t\t\t\t},\n111\t\t\t\t// Add default policy for KubernetesCredentialProvidersDir\n112\t\t\t\t{\n113\t\t\t