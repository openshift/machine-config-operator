{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01T6gR5HCJbALZuDhk4F7nH1","type":"tool_result","content":"1\tpackage extended\n2\t\n3\timport (\n4\t\t\"encoding/json\"\n5\t\t\"fmt\"\n6\t\t\"reflect\"\n7\t\n8\t\texutil \"github.com/openshift/machine-config-operator/test/extended-priv/util\"\n9\t)\n10\t\n11\t// NodeDisruptionPolicy, represents content of machineconfigurations.operator.openshift.io/cluster\n12\ttype NodeDisruptionPolicy struct {\n13\t\tResource `json:\"-\"`\n14\t\tSnapshot string    `json:\"-\"`\n15\t\tFiles    []*Policy `json:\"files,omitempty\"`\n16\t\tUnits    []*Policy `json:\"units,omitempty\"`\n17\t\tSSHKey   *Policy   `json:\"sshkey,omitempty\"`\n18\t}\n19\t\n20\t// Policy, represents content of every policy\n21\ttype Policy struct {\n22\t\tName    *string  `json:\"name,omitempty\"`\n23\t\tPath    *string  `json:\"path\"`\n24\t\tActions []Action `json:\"actions\"`\n25\t}\n26\t\n27\t// Action, represents content of every action in policy\n28\ttype Action struct {\n29\t\tType    string   `json:\"type\"`\n30\t\tReload  *Service `json:\"reload,omitempty\"`\n31\t\tRestart *Service `json:\"restart,omitempty\"`\n32\t}\n33\t\n34\t// Service represents service info in reload/restart\n35\ttype Service struct {\n36\t\tName string `json:\"serviceName\"`\n37\t}\n38\t\n39\t// NewNodeDisruptionPolicy constructor of NodeDisruptionPolicy\n40\tfunc NewNodeDisruptionPolicy(oc *exutil.CLI) *NodeDisruptionPolicy {\n41\t\tndp := NodeDisruptionPolicy{Resource: *NewResource(oc.AsAdmin(), \"machineconfigurations.operator.openshift.io\", \"cluster\")}\n42\t\tndp.Snapshot = ndp.GetOrFail(\"{.spec.nodeDisruptionPolicy}\")\n43\t\treturn &ndp\n44\t}\n45\t\n46\t// NewPolicyWithParams constructor of Policy\n47\tfunc NewPolicyWithParams(path, name *string, actions ...Action) Policy {\n48\t\treturn Policy{Path: path, Name: name, Actions: actions}\n49\t}\n50\t\n51\t// NewActionWithParams constrctor of Action\n52\tfunc NewActionWithParams(actnType string, reload, restart *Service) Action {\n53\t\treturn Action{Type: actnType, Reload: reload, Restart: restart}\n54\t}\n55\t\n56\t// NewService constructor of Service\n57\tfunc NewService(name string) *Service {\n58\t\treturn &Service{Name: name}\n59\t}\n60\t\n61\t// NewReloadAction create new reload action\n62\tfunc NewReloadAction(serviceName string) Action {\n63\t\treturn NewActionWithParams(\"Reload\", NewService(serviceName), nil)\n64\t}\n65\t\n66\t// NewRestartAction create new restart action\n67\tfunc NewRestartAction(serviceName string) Action {\n68\t\treturn NewActionWithParams(\"Restart\", nil, NewService(serviceName))\n69\t}\n70\t\n71\t// NewCommonAction create new common action, only has type\n72\tfunc NewCommonAction(actnType string) Action {\n73\t\treturn NewActionWithParams(actnType, nil, nil)\n74\t}\n75\t\n76\t// Equals deep equal policies\n77\tfunc (p Policy) Equals(policy Policy) bool {\n78\t\treturn reflect.DeepEqual(p, policy)\n79\t}\n80\t\n81\t// IsUpdated check whether polcies in this object are synced to status\n82\tfunc (ndp NodeDisruptionPolicy) IsUpdated() (bool, error) {\n83\t\tlatest := NewNodeDisruptionPolicy(ndp.oc)\n84\t\terr := json.Unmarshal([]byte(ndp.GetOrFail(\"{.status.nodeDisruptionPolicyStatus.clusterPolicies}\")), &latest)\n85\t\tif err != nil {\n86\t\t\treturn false, err\n87\t\t}\n88\t\n89\t\tupdatedPolices := 0\n90\t\tfor _, file := range ndp.Files {\n91\t\t\tfor _, latestFile := range latest.Files {\n92\t\t\t\tif file.Equals(*latestFile) {\n93\t\t\t\t\tupdatedPolices++\n94\t\t\t\t}\n95\t\t\t}\n96\t\t}\n97\t\n98\t\tfor _, unit := range ndp.Units {\n99\t\t\tfor _, latestUnit := range latest.Units {\n100\t\t\t\tif unit.Equals(*latestUnit) {\n101\t\t\t\t\tupdatedPolices++\n102\t\t\t\t}\n103\t\t\t}\n104\t\t}\n105\t\n106\t\tif ndp.SSHKey != nil && ndp.SSHKey.Equals(*latest.SSHKey) {\n107\t\t\tupdatedPolices++\n108\t\t}\n109\t\n110\t\tcurrentPolicies := len(ndp.Files) + len(ndp.Units)\n111\t\tif ndp.SSHKey != nil {\n112\t\t\tcurrentPolicies++\n113\t\t}\n114\t\n115\t\treturn updatedPolices == currentPolicies, nil\n116\t\n117\t}\n118\t\n119\t// Rollback rollback the spec to the original values, it should be called in defer block\n120\tfunc (ndp NodeDisruptionPolicy) Rollback() {\n121\t\tif ndp.Snapshot != \"\" {\n122\t\t\tndp.Patch(\"json\", fmt.Sprintf(`[{\"op\": \"replace\", \"path\": \"/spec/nodeDisruptionPolicy\", \"value\": %s}]`, ndp.Snapshot))\n123\t\t} else {\n124\t\t\tndp.Patch(\"json\", `[{\"op\": \"remove\", \"path\": \"/spec/nodeDisruptionPolicy\"}]`)\n125\t\t}\n126\t}\n127\t\n128\t// AddFilePolicy add file based policy\n129\tfunc (ndp NodeDisruptionPolicy) AddFilePolicy(path string, actions ...Action) NodeDisruptionPolicy {\n130\t\tpolicy := NewPolicyWithParams(&path, nil, actions...)\n131\t\tndp.Files = append(ndp.Files, &policy)\n132\t\treturn ndp\n133\t}\n134\t\n135\t// AddUnitPolicy add unit based policy\n136\tfunc (ndp NodeDisruptionPolicy) AddUnitPolicy(name string, actions ...Action) NodeDisruptionPolicy {\n137\t\tpolicy := NewPolicyWithParams(nil, &name, actions...)\n138\t\tndp.Units = append(ndp.Units, &policy)\n139\t\treturn ndp\n140\t}\n141\t\n142\t// SetSSHKeyPolicy set actions for sshkey based policy\n143\tfunc (ndp NodeDisruptionPolicy) SetSSHKeyPolicy(actions ...Action) NodeDisruptionPolicy {\n144\t\tpolicy := NewPolicyWithParams(nil, nil, actions...)\n145\t\tndp.SSHKey = &policy\n146\t\treturn ndp\n147\t}\n148\t\n149\t// Apply apply changes to machineconfiguration/cluster\n150\tfunc (ndp NodeDisruptionPolicy) Apply() error {\n151\t\tbytes, err := json.Marshal(ndp)\n152\t\tif err != nil {\n153\t\t\treturn err\n154\t\t}\n155\t\n156\t\terr = ndp.Patch(\"merge\", fmt.Sprintf(`{\"spec\":{\"nodeDisruptionPolicy\":%s}}`, string(bytes)))\n157\t\tif err != nil {\n158\t\t\treturn err\n159\t\t}\n160\t\n161\t\treturn nil\n162\t}\n163\t"}]},"parent_tool_use_id":"toolu_vrtx_012eYNRCZfJyWnRLE9EjXoPk","session_id":"1ca7e20c-f463-4aff-8411-4663c8d63aa4","uuid":"267d7138-0fae-487e-bf