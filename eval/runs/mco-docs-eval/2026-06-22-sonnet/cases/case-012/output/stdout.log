{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01LicCHWRE59dEctUYBEq5Lj","type":"tool_result","content":"655\tfunc calculatePostConfigChangeNodeDisruptionActionFromMCDiffs(diffSSH bool, diffFileSet, diffUnitSet []string, clusterPolicies opv1.NodeDisruptionPolicyClusterStatus) []opv1.NodeDisruptionPolicyStatusAction {\n656\t\tactions := []opv1.NodeDisruptionPolicyStatusAction{}\n657\t\n658\t\t// Step through all file based policies, and build out the actions object\n659\t\tfor _, diffPath := range diffFileSet {\n660\t\t\tpathFound, actionsFound := ctrlcommon.FindClosestFilePolicyPathMatch(diffPath, clusterPolicies.Files)\n661\t\t\tif pathFound {\n662\t\t\t\tklog.Infof(\"NodeDisruptionPolicy %v found for diff file %s\", actionsFound, diffPath)\n663\t\t\t\tactions = append(actions, actionsFound...)\n664\t\t\t} else {\n665\t\t\t\t// If this file path has no policy defined, default to reboot\n666\t\t\t\tklog.V(4).Infof(\"no policy found for diff path %s\", diffPath)\n667\t\t\t\treturn []opv1.NodeDisruptionPolicyStatusAction{{\n668\t\t\t\t\tType: opv1.RebootStatusAction,\n669\t\t\t\t}}\n670\t\t\t}\n671\t\t}\n672\t\n673\t\t// Step through all unit based policies, and build out the actions object\n674\t\tfor _, diffUnit := range diffUnitSet {\n675\t\t\tunitFound := false\n676\t\t\tfor _, policyUnit := range clusterPolicies.Units {\n677\t\t\t\tklog.V(4).Infof(\"comparing policy unit name %s to diff unit name %s\", string(policyUnit.Name), diffUnit)\n678\t\t\t\tif string(policyUnit.Name) == diffUnit {\n679\t\t\t\t\tklog.Infof(\"NodeDisruptionPolicy %v found for diff unit %s!\", policyUnit.Actions, diffUnit)\n680\t\t\t\t\tactions = append(actions, policyUnit.Actions...)\n681\t\t\t\t\tunitFound = true\n682\t\t\t\t\tbreak\n683\t\t\t\t}\n684\t\t\t}\n685\t\t\tif !unitFound {\n686\t\t\t\t// If this unit has no policy defined, default to reboot\n687\t\t\t\tklog.V(4).Infof(\"no policy found for diff unit %s\", diffUnit)\n688\t\t\t\treturn []opv1.NodeDisruptionPolicyStatusAction{{\n689\t\t\t\t\tType: opv1.RebootStatusAction,\n690\t\t\t\t}}\n691\t\t\t}\n692\t\t}\n693\t\n694\t\t// SSH only has one possible policy(and there is a default), so blindly add that if there is an SSH diff\n695\t\tif diffSSH {\n696\t\t\tklog.Infof(\"SSH diff detected, applying SSH policy %v\", clusterPolicies.SSHKey.Actions)\n697\t\t\tactions = append(actions, clusterPolicies.SSHKey.Actions...)\n698\t\t}\n699\t\n700\t\t// If any of the actions need a reboot, then just return a single Reboot action\n701\t\tif apihelpers.CheckNodeDisruptionActionsForTargetActions(actions, opv1.RebootStatusAction) {\n702\t\t\treturn []opv1.NodeDisruptionPolicyStatusAction{{\n703\t\t\t\tType: opv1.RebootStatusAction,\n704\t\t\t}}\n705\t\t}\n706\t\n707\t\t// If there is a \"None\" action in conjunction with other kinds of actions, strip out the \"None\" action elements as it is redundant\n708\t\tif apihelpers.CheckNodeDisruptionActionsForTargetActions(actions, opv1.NoneStatusAction) {\n709\t\t\tif apihelpers.CheckNodeDisruptionActionsForTargetActions(actions, opv1.DrainStatusAction, opv1.ReloadStatusAction, opv1.RestartStatusAction, opv1.DaemonReloadStatusAction, opv1.SpecialStatusAction) {\n710\t\t\t\tfinalActions := []opv1.NodeDisruptionPolicyStatusAction{}\n711\t\t\t\tfor _, action := range actions {\n712\t\t\t\t\tif action.Type != opv1.NoneStatusAction {\n713\t\t\t\t\t\tfinalActions = append(finalActions, action)\n714\t\t\t\t\t}\n715\t\t\t\t}\n716\t\t\t\treturn finalActions\n717\t\t\t}\n718\t\t\t// If we're here, this means that the action list has only \"None\" actions; return a single \"None\" Action\n719\t\t\treturn []opv1.NodeDisruptionPolicyStatusAction{{\n720\t\t\t\tType: opv1.NoneStatusAction,\n721\t\t\t}}\n722\t\t}\n723\t\n724\t\t// If we're here, return as is - this means action list had zero \"None\" actions in the list\n725\t\treturn actions\n726\t}\n727\t\n728\tfunc calculatePostConfigChangeAction(diff *machineConfigDiff, diffFileSet []string) ([]string, error) {\n729\t\t// If a machine-config-daemon-force file is present, it means the user wants to\n730\t\t// move to desired state without additional validation. We will reboot the node in\n731\t\t// this case regardless of what MachineConfig diff is.\n732\t\tif _, err := os.Stat(constants.MachineConfigDaemonForceFile); err == nil {\n733\t\t\tif err := os.Remove(constants.MachineConfigDaemonForceFile); err != nil {\n734\t\t\t\treturn []string{}, fmt.Errorf(\"failed to remove force validation file: %w\", err)\n735\t\t\t}\n736\t\t\tklog.Infof(\"Setting post config change action to postConfigChangeActionReboot; %s present\", constants.MachineConfigDaemonForceFile)\n737\t\t\treturn []string{postConfigChangeActionReboot}, nil\n738\t\t}\n739\t\n740\t\tif diff.osUpdate || diff.kargs || diff.fips || diff.units || diff.kernelType || diff.extensions {\n741\t\t\t// must reboot\n742\t\t\treturn []string{postConfigChangeActionReboot}, nil\n743\t\t}\n744\t\n745\t\t// Calculate actions based on file, unit and ssh diffs\n746\t\treturn calculatePostConfigChangeActionFromMCDiffs(diffFileSet), nil\n747\t}\n748\t\n749\t// calculatePostConfigChangeNodeDisruptionAction takes action based on the cluster's Node disruption policies.\n750\tfunc (dn *Daemon) calculatePostConfigChangeNodeDisruptionAction(diff *machineConfigDiff, diffFileSet, diffUnitSet []string) ([]opv1.NodeDisruptionPolicyStatusAction, error) {\n751\t\n752\t\tvar mcop *opv1.MachineConfiguration\n753\t\tvar pollErr error\n754\t\t// Wait for mcop.Status.NodeDisruptionPolicyStatus to populate, otherwise error out. This shouldn't take very long\n755\t\t// as this is done by the operator sync loop, but may be extended if transitioning to TechPreview as the operator restarts,\n756\t\tif err := wait.PollUntilContextTimeout(context.TODO(), 5*time.Second, 2*time.Minute, true, func(_ context.Context) (bool, error) {\n757\t\t\tmcop, pollErr = dn.mcopClient.OperatorV1().MachineConfigurations().Get(context.TODO(), ctrlcommon.MCOOperatorKnobsObjectName, metav1.GetOptions{})\n758\t\t\tif pollErr != nil {\n759\t\t\t\tklog.Errorf(\"calculating NodeDisruptionPolicies: MachineConfiguration/cluster has not been created yet\")\n760\t\t\t\tpollErr = fmt.Errorf(\"MachineConfiguration/cluster has not been created yet\")\n761\t\t\t\treturn false, nil\n762\t\t\t}\n763\t\n764\t\t\t// Ensure status.ObservedGeneration matches the last generation of MachineConfiguration\n765\t\t\tif mcop.Generation != mcop.Status.ObservedGeneration {\n766\t\t\t\tklog.Errorf(\"calculating NodeDisruptionPolicies: NodeDisruptionPolicyStatus is not up to date.\")\n767\t\t\t\tpollErr = fmt.Errorf(\"NodeDisruptionPolicyStatus is not up to date\")\n768\t\t\t\treturn false, nil\n769\t\t\t}\n770\t\t\treturn true, nil\n771\t\t}); err != nil {\n772\t\t\tklog.Errorf(\"NodeDisruptionPolicyStatus was not ready: %v\", pollErr)\n773\t\t\treturn nil, fmt.Errorf(\"NodeDisruptionPolicyStatus was not ready: %v\", pollErr)\n774\t\t}\n775\t\n776\t\t// Continue policy calculation if no errors were encountered in fetching the policy.\n777\t\t// If a machine-config-daemon-force file is present, it means the user wants to\n778\t\t// move to desired state without additional validation. We will reboot the node in\n779\t\t// this case regardless of what MachineConfig diff is.\n780\t\tklog.Infof(\"Calculating node disruption actions\")\n781\t\tif _, err := os.Stat(constants.MachineConfigDaemonForceFile); err == nil {\n782\t\t\tif err = os.Remove(constants.MachineConfigDaemonForceFile); err != nil {\n783\t\t\t\treturn []opv1.NodeDisruptionPolicyStatusAction{}, fmt.Errorf(\"failed to remove force validation file: %w\", err)\n784\t\t\t}\n785\t\t\tklog.Infof(\"Setting post config change node disruption action to Reboot; %s present\", constants.MachineConfigDaemonForceFile)\n786\t\t\treturn []opv1.NodeDisruptionPolicyStatusAction{{\n787\t\t\t\tType: opv1.RebootStatusAction,\n788\t\t\t}}, nil\n789\t\t}\n790\t\n791\t\tif diff.osUpdate || diff.kargs || diff.fips || diff.kernelType || diff.extensions {\n792\t\t\t// must reboot\n793\t\t\treturn []opv1.NodeDisruptionPolicyStatusAction{{\n794\t\t\t\tType: opv1.RebootStatusAction,\n795\t\t\t}}, nil\n796\t\t}\n797\t\tif !diff.files && !diff.units && !diff.passwd {\n798\t\t\t// This is a diff which requires no actions\n799\t\t\tklog.Infof(\"No changes in files, units or SSH keys, no NodeDisruptionPolicies are in effect\")\n800\t\t\treturn []opv1.NodeDisruptionPolicyStatusAction{{\n801\t\t\t\tType: opv1.NoneStatusAction,\n802\t\t\t}}, nil\n803\t\t}\n804\t\n805\t\t// Calculate actions based on file, unit and ssh diffs\n806\t\tnodeDisruptionActions := calculatePostConfigChangeNodeDisruptionActionFromMCDiffs(diff.passwd, diffFileSet, diffUnitSet, mcop.Status.NodeDisruptionPolicyStatus.ClusterPolicies)\n807\t\n808\t\t// Print out node disruption actions for debug purposes\n809\t\tklog.Infof(\"Calculated node disruption actions:\")\n810\t\tfor _, action := range nodeDisruptionActions {\n811\t\t\tswitch action.Type {\n812\t\t\tcase opv1.ReloadStatusAction:\n813\t\t\t\tklog.Infof(\"%v - %v\", action.Type, action.Reload.ServiceName)\n814\t\t\tcase opv1.RestartStatusAction:"}]},"parent_tool_use_id":"toolu_vrtx_012eYNRCZfJyWnRLE9EjXoPk","session_id":"1ca7e20c-f463-4aff-8411-4663c8d63aa4","uuid":"9bc38593-52fc-41a7-8b11-6914b89ba3f6","timestamp":"2026-06-22T21:24:27.207Z","subagent_type":"Explore","task_description":"Find NodeDisruptionPolicy API types and examples"}
