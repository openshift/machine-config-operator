{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01K1FAd7p9xUNmNAVCwGEVE4","type":"tool_result","content":"718\t// +openshift:api-approved.openshift.io=https://github.com/openshift/api/pull/1453\n719\t// +openshift:file-pattern=cvoRunLevel=0000_80,operatorName=machine-config,operatorOrdering=01\n720\t// +kubebuilder:metadata:labels=\"openshift.io/operator-managed=\"\n721\t// +openshift:compatibility-gen:level=1\n722\ttype KubeletConfig struct {\n723\t\tmetav1.TypeMeta   `json:\",inline\"`\n724\t\tmetav1.ObjectMeta `json:\"metadata,omitempty\"`\n725\t\n726\t\t// spec contains the desired kubelet configuration.\n727\t\t// +required\n728\t\tSpec KubeletConfigSpec `json:\"spec\"`\n729\t\n730\t\t// status contains observed information about the kubelet configuration.\n731\t\t// +optional\n732\t\tStatus KubeletConfigStatus `json:\"status\"`\n733\t}\n734\t\n735\t// KubeletConfigSpec configures the kubelet running on cluster nodes.\n736\ttype KubeletConfigSpec struct {\n737\t\t// autoSizingReserved controls whether system-reserved CPU and memory are automatically\n738\t\t// calculated based on each node's installed capacity. When set to true, this prevents node failure\n739\t\t// from resource starvation of system components (kubelet, CRI-O) without manual configuration.\n740\t\t// When omitted, this means the user has no opinion and the platform is left to choose a reasonable default,\n741\t\t// which is subject to change over time. The current default is true for worker nodes and false for control plane nodes.\n742\t\t// When set to false, automatic resource reservation is disabled and manual settings must be configured.\n743\t\t// +optional\n744\t\tAutoSizingReserved *bool `json:\"autoSizingReserved,omitempty\"`\n745\t\t// logLevel sets the kubelet log verbosity, controlling the amount of detail in kubelet logs.\n746\t\t// Valid values range from 0 (minimal logging) to 10 (maximum verbosity with trace-level detail).\n747\t\t// Higher log levels may impact node performance. When omitted, the platform chooses a reasonable default,\n748\t\t// which is subject to change over time. The current default is 2 (standard informational logging).\n749\t\t// +kubebuilder:validation:Minimum=0\n750\t\t// +kubebuilder:validation:Maximum=10\n751\t\t// +optional\n752\t\tLogLevel *int32 `json:\"logLevel,omitempty\"`\n753\t\n754\t\t// machineConfigPoolSelector selects which pools the KubeletConfig should apply to.\n755\t\t// When omitted or set to an empty selector {}, no pools are selected, which is equivalent\n756\t\t// to not matching any MachineConfigPool.\n757\t\t// +optional\n758\t\tMachineConfigPoolSelector *metav1.LabelSelector `json:\"machineConfigPoolSelector,omitempty\"`\n759\t\t// kubeletConfig contains upstream Kubernetes kubelet configuration fields.\n760\t\t// Values are validated by the kubelet itself. Invalid values may render nodes unusable.\n761\t\t// Refer to OpenShift documentation for the Kubernetes version corresponding to your\n762\t\t// OpenShift release to find valid kubelet configuration options.\n763\t\t// +optional\n764\t\tKubeletConfig *runtime.RawExtension `json:\"kubeletConfig,omitempty\"`\n765\t\n766\t\t// tlsSecurityProfile configures TLS settings for the kubelet.\n767\t\t// When omitted, the TLS configuration defaults to the value from apiservers.config.openshift.io/cluster.\n768\t\t// When specified, the type field can be set to either \"Old\", \"Intermediate\", \"Modern\", \"Custom\" or omitted for backward compatibility.\n769\t\t// +optional\n770\t\tTLSSecurityProfile *configv1.TLSSecurityProfile `json:\"tlsSecurityProfile,omitempty\"`\n771\t}\n772\t\n773\t// KubeletConfigStatus defines the observed state of a KubeletConfig\n774\ttype KubeletConfigStatus struct {\n775\t\t// observedGeneration represents the generation observed by the controller.\n776\t\t// +optional\n777\t\tObservedGeneration int64 `json:\"observedGeneration,omitempty\"`\n778\t\n779\t\t// conditions represents the latest available observations of current state.\n780\t\t// +optional\n781\t\t// +listType=atomic\n782\t\tConditions []KubeletConfigCondition `json:\"conditions\"`\n783\t}\n784\t\n785\t// KubeletConfigCondition defines the state of the KubeletConfig\n786\ttype KubeletConfigCondition struct {\n787\t\t// type specifies the state of the operator's reconciliation functionality.\n788\t\t// +optional\n789\t\tType KubeletConfigStatusConditionType `json:\"type\"`\n790\t\n791\t\t// status of the condition, one of True, False, Unknown.\n792\t\t// +optional\n793\t\tStatus corev1.ConditionStatus `json:\"status,omitempty\"`\n794\t\n795\t\t// lastTransitionTime is the time of the last update to the current status object.\n796\t\t// +optional\n797\t\t// +nullable\n798\t\tLastTransitionTime metav1.Time `json:\"lastTransitionTime\"`\n799\t\n800\t\t// reason is the reason for the condition's last transition.  Reasons are PascalCase\n801\t\t// +optional\n802\t\tReason string `json:\"reason,omitempty\"`\n803\t\n804\t\t// message provides additional information about the current condition.\n805\t\t// This is only to be consumed by humans.\n806\t\t// +optional\n807\t\tMessage string `json:\"message,omitempty\"`\n808\t}\n809\t\n810\t// KubeletConfigStatusConditionType is the state of the operator's reconciliation functionality.\n811\ttype KubeletConfigStatusConditionType string\n812\t\n813\tconst (\n814\t\t// KubeletConfigSuccess designates a successful application of a KubeletConfig CR.\n815\t\tKubeletConfigSuccess KubeletConfigStatusConditionType = \"Success\"\n816\t\n817\t\t// KubeletConfigFailure designates a failure applying a KubeletConfig CR.\n818\t\tKubeletConfigFailure KubeletConfigStatusConditionType = \"Failure\"\n819\t)\n820\t\n821\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n822\t\n823\t// KubeletConfigList is a list of KubeletConfig resources\n824\t//\n825\t// Compatibility level 1: Stable within a major release for a minimum of 12 months or 3 minor releases (whichever is longer).\n826\t// +openshift:compatibility-gen:level=1\n827\ttype KubeletConfigList struct {\n828\t\tmetav1.TypeMeta `json:\",inline\"`\n829\t\tmetav1.ListMeta `json:\"metadata\"`\n830\t\n831\t\tItems []KubeletConfig `json:\"items\"`\n832\t}\n833\t\n834\t// +genclient\n835\t// +genclient:nonNamespaced\n836\t// +k8s:deepcopy-gen:interfaces=k8s.io/apimachinery/pkg/runtime.Object\n837\t"}]},"parent_tool_use_id":"toolu_vrtx_01AfxYpE4RBeXH8VZdwSLs5P","session_id":"c2fd8390-c847-413c-9495-3acc22b6bd40","uuid":"88789278-61e3-4a90-95d2-ff6ceee9f5ef","timestamp":"2026-06-22T21:06:11.425Z","subagent_type":"Explore","task_description":"Find KubeletConfig usage examples and documentation"}
